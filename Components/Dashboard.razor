@code {
    


    private string conn = @"Server=.\SQLEXPRESS;Database=GestAgenti;Trusted_Connection=True;TrustServerCertificate=True;";
    private PerformanceData datiOggi = new(), datiSettimana = new(), datiMese = new(), datiAnno = new();
    private List<dynamic> listaRitardi = new();
    private List<ClienteDormiente> listaDormienti = new();
    private int ordiniAnno;
    private int resiAnno;
    private int visiteAnno;
    // Variabile per mostrare/nascondere il popup
    bool showPopupTask = false;
    Attivita nuovoTask = new Attivita(); 
    List<Attivita> listaAttivita = new List<Attivita>();
    private List<Cliente> listaClienti = new();
    private List<Prodotti> listaProdotti = new();
    

    protected override async Task OnInitializedAsync()
{
    try
    {
        using var db = new SqlConnection(conn);
        listaClienti = (await db.QueryAsync<Cliente>("SELECT IDCliente, RagSociale FROM Clienti ORDER BY RagSociale")).ToList();
        listaProdotti = (await db.QueryAsync<Prodotti>("SELECT IDProdotto, CodiceProdotto FROM Prodotti ORDER BY CodiceProdotto")).ToList();

        // 1. PERFORMANCE
        datiOggi = await GetPerformance(db, DateTime.Today);
        datiSettimana = await GetPerformance(db, DateTime.Today.AddDays(-7));
        datiMese = await GetPerformance(db, new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1));
        datiAnno = await GetPerformance(db, new DateTime(DateTime.Today.Year, 1, 1));
        StateHasChanged(); // Forza il caricamento del primo blocco

        // 2. RITARDI (Specifica la classe se esiste, altrimenti usa dynamic)
        string sqlRitardi = @"
            SELECT TOP 10 c.IdCliente AS IDClienteAttivita, c.RagSociale, o.NumeroDocumento, o.DataConsegnaPrevista
            FROM Ordini o 
            JOIN Clienti c ON o.IDCliente = c.IdCliente
            WHERE o.DataConsegnaPrevista < GETDATE() AND o.DataConsegnaEffettiva IS NULL
            ORDER BY o.DataConsegnaPrevista ASC";
        
        // CORREZIONE: Se non hai una classe specifica per i ritardi, usa dynamic
        var resRitardi = await db.QueryAsync<dynamic>(sqlRitardi);
        listaRitardi = resRitardi.ToList();
        StateHasChanged();

        // 3. PROMEMORIA (L'ultimo inserito)
        string sqlAttivita = @"
            SELECT a.*, c.RagSociale as NomeRiferimento
            FROM Attivita a
            LEFT JOIN Clienti c ON a.IDClienteAttivita = c.IdCliente
            WHERE a.Completata = 0";
        
        listaAttivita = (await db.QueryAsync<Attivita>(sqlAttivita)).ToList();
        StateHasChanged();

        // 4. DORMIENTI
        string sqlDormienti = @"
    SELECT TOP 10 
        c.IDCliente, 
        c.RagSociale, 
        MAX(o.DataOrdine) as UltimoOrdine, 
        DATEDIFF(DAY, MAX(o.DataOrdine), GETDATE()) as GiorniAssenza,
        (SELECT MAX(DataVisita) FROM Visite v WHERE v.IDCliente = c.IDCliente) as UltimaVisita
    FROM Clienti c
    LEFT JOIN Ordini o ON c.IDCliente = o.IDCliente
    GROUP BY c.IDCliente, c.RagSociale
    /* Mostra chi non ordina da più di 30 giorni o non ha mai ordinato */
    HAVING MAX(o.DataOrdine) < DATEADD(DAY, -30, GETDATE()) OR MAX(o.DataOrdine) IS NULL
    ORDER BY GiorniAssenza DESC";
var resDormienti = await db.QueryAsync<ClienteDormiente>(sqlDormienti);
listaDormienti = resDormienti.ToList();
StateHasChanged(); // Forza l'aggiornamento finale della pagina
    }
    catch (Exception ex)
    {
        // Se la pagina è vuota, l'errore apparirà qui sotto nella console di debug
        Console.WriteLine($"ERRORE CRITICO DASHBOARD: {ex.Message}");
    }
}

    
    public async Task<List<Attivita>> GetAttivitaAperte()
{
    using var db = new SqlConnection(conn);
    string sql = @"
        SELECT a.*, 
               c.RagSociale as NomeRiferimento,
               p.CodiceProdotto as CodiceRiferimento
        FROM Attivita a
        LEFT JOIN Clienti c ON a.IDClienteAttivita = c.IDCliente
        LEFT JOIN Prodotti p ON a.IDProdottoAttivita = p.IDProdotto
        WHERE a.Completata = 0
        ORDER BY a.Priorita DESC, a.DataScadenza ASC";
    
    var lista = await db.QueryAsync<Attivita>(sql);
    return lista.ToList();
}

    private void ApriNuovoTask()
{
    nuovoTask = new Attivita { DataScadenza = DateTime.Today, Priorita = 1 };
    showPopupTask = true;
}

private async Task SalvaTask() {
    using var db = new SqlConnection(conn);
    string sql = "INSERT INTO Attivita (Descrizione, DataScadenza, Priorita, Completata, IDClienteAttivita, IDProdottoAttivita) VALUES (@Descrizione, @DataScadenza, @Priorita, 0, NULLIF(@IDClienteAttivita, 0), NULLIF(@IDProdottoAttivita, 0))";
    await db.ExecuteAsync(sql, nuovoTask);
    showPopupTask = false;
    // Ricarica la lista
    listaAttivita = await GetAttivitaAperte();
    StateHasChanged();
}

private async Task SegnaCompletato(int id) {
    using var db = new SqlConnection(conn);
    await db.ExecuteAsync("UPDATE Attivita SET Completata = 1 WHERE IDAttivita = @id", new { id });
    listaAttivita.RemoveAll(x => x.IDAttivita == id);
}


// Sollecita Ordine in Ritardo
private void SollecitaOrdine(string cliente, string numDoc, int idClientePassato)
{
    nuovoTask = new Attivita 
    { 
        Descrizione = $"📞 Sollecitare consegna Ordine {numDoc} - {cliente}",
        DataScadenza = DateTime.Today,
        IDClienteAttivita = idClientePassato,
        Priorita = 3, // Alta priorità per i solleciti
        
    };
    showPopupTask = true;
}

// Pianifica Visita Cliente Dormiente
private void PianificaVisitaDormiente(string cliente, int idCliente)
{
    nuovoTask = new Attivita 
    { 
        Descrizione = $"📅 Pianificare visita commerciale: {cliente}",
        DataScadenza = DateTime.Today.AddDays(1), // Scadenza domani
        Priorita = 2,
        IDClienteAttivita = idCliente
    };
    showPopupTask = true;
}




private void ChiudiPopup()
{
    showPopupTask = false;
}
    
    private async Task<PerformanceData> GetPerformance(SqlConnection db, DateTime dataInizio)
    {
        var p = new PerformanceData();

        // Conteggio Ordini e Fatturato
        var statsOrdini = await db.QueryFirstOrDefaultAsync(@"
            SELECT COUNT(IDOrdine) as Conteggio, SUM(TotaleImponibile) as Totale 
            FROM Ordini 
            WHERE DataOrdine >= @dataInizio 
            AND StatoOrdine = 'Ordine'", new { dataInizio });
        
        p.Ordini = statsOrdini?.Conteggio ?? 0;
        p.Fatturato = statsOrdini?.Totale ?? 0;

        // Conteggio Visite
        p.Visite = await db.ExecuteScalarAsync<int>(@"
            SELECT COUNT(IDVisita) FROM Visite WHERE DataVisita >= @dataInizio", new { dataInizio });

        // Conteggio Resi
        p.Resi = await db.ExecuteScalarAsync<int>(@"
            SELECT COUNT(IDReso) FROM Resi WHERE DataReso >= @dataInizio", new { dataInizio });

        return p;
    }

    public class PerformanceData
    {
        public decimal Fatturato { get; set; } = 0;
        public int Ordini { get; set; } = 0;
        public int Visite { get; set; } = 0;
        public int Resi { get; set; } = 0;
    }

    public class ClienteDormiente
    {
        public int IDCliente { get; set; }
        public string RagSociale { get; set; }
        public DateTime? UltimoOrdine { get; set; }
        public int? GiorniAssenza { get; set; }
        public DateTime? UltimaVisita { get; set; }
    }

    private int openMenuFor = -1;

    private void ToggleMenu(int id)
    {
        if (openMenuFor == id) openMenuFor = -1; else openMenuFor = id;
    }

    private void OpenNuovaVisita(int idCliente)
    {
        ToggleMenu(-1);
        Nav.NavigateTo($"/nuova-visita?idCliente={idCliente}&stato=Programmata");
    }

    private void OpenCliente(int idCliente)
