@page "/nuova-visita"
@rendermode InteractiveServer
@using Microsoft.Data.SqlClient
@using Dapper
@using GestioneCommerciale.Models
@using System.Text.Json
@using System.Globalization
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .win-form { background-color: #f0f0f0; font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 11px; border: 1px solid #999; padding: 5px; min-width: 1150px; color: #333; position: relative; min-height: 98vh; }
    .win-header { background: #005a9e; color: white; padding: 3px 8px; font-weight: bold; margin: -5px -5px 5px -5px; font-size: 12px; }
    .win-group { border: 1px solid #c0c0c0; background: #fff; padding: 8px; margin-bottom: 5px; }
    .win-label { font-weight: 500; color: #333; padding-right: 5px; white-space: nowrap; text-align: right; font-size: 10.5px; }
    .win-input { border: 1px solid #ccc; padding: 1px 4px; height: 21px; width: 100%; font-size: 11px; }
    .toolbar-container { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 5px; background: #fdfdfd; border: 1px solid #c0c0c0; margin-bottom: 5px; }
    .win-btn { background: #e1e1e1; border: 1px solid #adadad; padding: 0 15px; color: black; font-size: 11px; height: 72px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; min-width: 85px; text-decoration:none; }
    .win-btn:hover { background: #e5f1fb; border-color: #0078d7; }
    .section-title { font-weight: bold; color: #005a9e; border-bottom: 1px solid #ddd; margin-bottom: 8px; font-size: 10px; text-transform: uppercase; }
    .toast-msg { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 12px 30px; border-radius: 3px; z-index: 9999; box-shadow: 0 5px 15px rgba(0,0,0,0.4); border-left: 5px solid #005a9e; font-size: 13px; }
    .vicini-box { font-size: 10px; border-bottom: 1px solid #eee; padding: 4px 0; display: flex; justify-content: space-between; align-items: center; }
    .btn-waze-sm { background: #333; color: white; border: none; padding: 2px 5px; cursor: pointer; border-radius: 3px; font-size: 12px; }
    .win-table { width: 100%; border-collapse: collapse; background: white; font-size: 10px; }
    .win-table th { background: #f0f0f0; border: 1px solid #ccc; padding: 4px; text-align: left; position: sticky; top:0; }
    .win-table td { border: 1px solid #eee; padding: 4px; vertical-align: top; }
</style>

<div class="win-form">
    <div class="win-header">Gestione Visite Professional - CRM GestAgenti by Riccardo Gucci soft.</div>

    <div class="toolbar-container">
        <div style="display:flex; gap:5px;">
            <button class="win-btn" @onclick="CheckAndGoHome">🏠 Home</button>
            <button class="win-btn" @onclick="Prev" disabled="@(indiceCorrente <= 0)">◀ Prec.</button>
            <button class="win-btn" @onclick="Next" disabled="@(indiceCorrente >= listaIdVisite.Count - 1 || indiceCorrente == -1)">Succ. ▶</button>
        </div>
        
        <div style="flex-grow: 1; max-width: 400px; display:flex; gap:0;">
            <input type="text" class="win-input" style="height:36px; font-size:13px; border-right:none; border-radius: 2px 0 0 2px;" placeholder="Cerca Cliente..." @bind="testoRicerca" @bind:event="oninput" @onkeyup="CercaEnter" />
            <button style="height:36px; width:40px; background:#e1e1e1; border:1px solid #ccc; cursor:pointer; border-radius: 0 2px 2px 0;" @onclick="EseguiRicerca">🔍</button>
        </div>

        <div style="display:flex; gap:5px;">
            <button class="win-btn" @onclick="Nuovo" style="background:#fff;">📄 Nuova</button>
            <button class="win-btn" @onclick="Annulla" style="background:#f1f1f1;">✖ Annulla</button>
            <button class="win-btn" @onclick="Salva" style="background:#d4edda; border-color:#28a745;">💾 Salva</button>
            @if(v.IDVisita > 0) {
                <button class="win-btn" @onclick="Elimina" style="background:#f8d7da; border-color:#dc3545; color:#721c24;">🗑 Elimina</button>
            }
        </div>
    </div>

    <div style="display: flex; gap: 10px;">
        <div style="flex: 2;">
            <div class="win-group">
                <div class="section-title">Dati Rapporto</div>
                <table style="width:100%; border-spacing: 4px; table-layout: fixed;">
                    <tr>
                        <td style="width:15%" class="win-label">Cliente:</td>
                        <td>
                            <div style="display:flex; gap:2px;">
                                <select class="win-input fw-bold" @bind="v.IDCliente" @bind:after="AlCambioCliente">
                                    <option value="0">-- Seleziona --</option>
                                    @foreach (var cl in clienti) {
                                        <option value="@cl.IdCliente">@cl.RagSociale</option>
                                    }
                                </select>
                                <button type="button" class="btn-waze-sm" title="Naviga" 
                                        disabled="@(clienteSelezionato == null)" @onclick="() => NavigaWaze(clienteSelezionato)">🚙</button>
                            </div>
                        </td>
                        <td style="width:15%" class="win-label">Data Visita:</td>
                        <td><input type="date" class="win-input" @bind="v.DataVisita" /></td>
                    </tr>
                    <tr>
                        <td class="win-label">Motivazione:</td>
                        <td><input type="text" class="win-input" @bind="v.Motivazione" /></td>
                        <td class="win-label">Referente:</td>
                        <td><input type="text" class="win-input" @bind="v.ReferenteIncontrato" /></td>
                    </tr>
                    <tr>
                        <td class="win-label">Esito:</td>
                        <td colspan="3"><textarea class="win-input" style="height:60px; resize:none;" @bind="v.NoteEsito"></textarea></td>
                    </tr>
                </table>
            </div>

            <!-- STORICO VISITE -->
            <div class="win-group">
                <div class="section-title">📜 Storico Visite Cliente</div>
                <div style="max-height: 250px; overflow-y: auto; border: 1px solid #ddd;">
                    <table class="win-table">
                        <thead>
                            <tr>
                                <th style="width:80px;">Data</th>
                                <th style="width:150px;">Motivazione</th>
                                <th>Esito / Note</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in storicoVisite) {
                                <tr style="@(s.IDVisita == v.IDVisita ? "background-color: #fff9c4; font-weight:bold;" : "")">
                                    <td>@s.DataVisita?.ToString("dd/MM/yyyy")</td>
                                    <td>@s.Motivazione</td>
                                    <td style="color:#555;">@s.NoteEsito</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div style="flex: 1;">
            <div class="win-group" style="height: 100%;">
                <div class="section-title">📍 Giro Intelligente</div>
                @if (clienteSelezionato != null)
                {
                    <div style="background:#f9f9f9; padding:5px; border:1px solid #ddd; margin-bottom:8px;">
                        <span style="font-size:9px; font-weight:bold;">CRITERIO:</span>
                        <select class="win-input" @onchange="OnFiltroGiroChanged">
                            <option value="provincia">Stessa Provincia</option>
                            <option value="comune">Stesso Comune</option>
                            <option value="distanza">Raggio 50 KM</option>
                        </select>
                    </div>

                    <div style="max-height: 450px; overflow-y: auto;">
                        @foreach (var vic in clientiVicini) {
                            <div class="vicini-box">
                                <div style="cursor:pointer; flex-grow:1;" @onclick="() => SelezionaDaGiro(vic.IdCliente)">
                                    <b>@vic.RagSociale</b><br /><span>@vic.Citta_Legale (@vic.Prov_Legale)</span>
                                </div>
                                <button type="button" class="btn-waze-sm" @onclick="() => NavigaWaze(vic)">🚙</button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (mostraMessaggio) { <div class="toast-msg">@testoNotifica</div> }

@code {
    private Visita v = new Visita { DataVisita = DateTime.Now };
    private Cliente clienteSelezionato;
    private List<Cliente> clienti = new();
    private List<Cliente> clientiVicini = new();
    private List<Visita> storicoVisite = new();
    private string tipoFiltroGiro = "provincia";
    private string snapshotOriginale = "";
    private List<int> listaIdVisite = new();
    private int indiceCorrente = -1;
    private string testoRicerca = "";
    private string testoNotifica = "";
    private bool mostraMessaggio = false;
    private string conn = @"Server=.\SQLEXPRESS;Database=GestAgenti;Trusted_Connection=True;TrustServerCertificate=True;";
    private int idPrecedente = 0;


    protected override async Task OnInitializedAsync() {
        await CaricaClienti();
        await CaricaListaId();
        if (listaIdVisite.Any()) {
            indiceCorrente = listaIdVisite.Count - 1;
            await CaricaVisita(listaIdVisite[indiceCorrente]);
        } else {
            snapshotOriginale = JsonSerializer.Serialize(v);
        }
    }

    private async Task CaricaClienti() {
        using var db = new SqlConnection(conn);
        clienti = (await db.QueryAsync<Cliente>("SELECT * FROM Clienti ORDER BY RagSociale")).ToList();
    }

    private async Task CaricaListaId() {
        using var db = new SqlConnection(conn);
        listaIdVisite = (await db.QueryAsync<int>("SELECT IDVisita FROM Visite ORDER BY DataVisita ASC, IDVisita ASC")).ToList();
    }

    private async Task CaricaVisita(int id) {
        using var db = new SqlConnection(conn);
        v = await db.QueryFirstOrDefaultAsync<Visita>("SELECT * FROM Visite WHERE IDVisita = @id", new { id });
        if (v != null) {
            await AlCambioCliente();
            snapshotOriginale = JsonSerializer.Serialize(v);
        }
    }

    private async Task AlCambioCliente() {
        if (v.IDCliente > 0) {
            clienteSelezionato = clienti.FirstOrDefault(c => c.IdCliente == v.IDCliente);
            using var db = new SqlConnection(conn);
            storicoVisite = (await db.QueryAsync<Visita>("SELECT * FROM Visite WHERE IDCliente = @id ORDER BY DataVisita DESC", new { id = v.IDCliente })).ToList();
            await CaricaClientiVicini();
        } else {
            clienteSelezionato = null;
            storicoVisite.Clear();
            clientiVicini.Clear();
        }
        StateHasChanged();
    }

    private async Task<bool> CheckModificheRealmenteFatte() {
        var attuale = JsonSerializer.Serialize(v);
        if (attuale != snapshotOriginale) {
            return await JS.InvokeAsync<bool>("confirm", "Sono state apportate modifiche. Vuoi uscire senza salvare?");
        }
        return true;
    }

    private async Task Nuovo() {
    if (!await CheckModificheRealmenteFatte()) return;

    // Memorizziamo l'ID attuale prima di resettare, così Annulla sa dove tornare
    if (v.IDVisita > 0) idPrecedente = v.IDVisita;

    v = new Visita { DataVisita = DateTime.Now, IDCliente = 0 };
    clienteSelezionato = null;
    storicoVisite.Clear();
    indiceCorrente = -1;
    snapshotOriginale = JsonSerializer.Serialize(v);
}

    private async Task Salva() {
        if (v.IDCliente <= 0) { await ShowToast("Seleziona un cliente!"); return; }
        using var db = new SqlConnection(conn);
        if (v.IDVisita == 0) {
            var sql = @"INSERT INTO Visite (IDCliente, DataVisita, Motivazione, ReferenteIncontrato, NoteEsito) 
                        VALUES (@IDCliente, @DataVisita, @Motivazione, @ReferenteIncontrato, @NoteEsito); SELECT CAST(SCOPE_IDENTITY() as int);";
            v.IDVisita = await db.ExecuteScalarAsync<int>(sql, v);
            await CaricaListaId();
            indiceCorrente = listaIdVisite.IndexOf(v.IDVisita);
        } else {
            await db.ExecuteAsync("UPDATE Visite SET IDCliente=@IDCliente, DataVisita=@DataVisita, Motivazione=@Motivazione, ReferenteIncontrato=@ReferenteIncontrato, NoteEsito=@NoteEsito WHERE IDVisita=@IDVisita", v);
        }
        snapshotOriginale = JsonSerializer.Serialize(v); // Aggiorna lo snapshot dopo il salvataggio
        await AlCambioCliente();
        await ShowToast("Salvataggio completato.");
    }

    private async Task Annulla() {
    var attuale = JsonSerializer.Serialize(v);
    
    // Se non è cambiato nulla rispetto allo snapshot, non chiediamo conferma
    if (attuale == snapshotOriginale) {
        // Se siamo in modalità "Nuovo" (ID=0) e abbiamo un ID precedente, torniamo lì
        if (v.IDVisita == 0 && idPrecedente > 0) {
            await CaricaVisita(idPrecedente);
            indiceCorrente = listaIdVisite.IndexOf(idPrecedente);
        }
        return;
    }

    // Se ci sono modifiche, chiediamo conferma
    if (!await JS.InvokeAsync<bool>("confirm", "Annullare le modifiche correnti?")) return;
    
    if (v.IDVisita > 0) {
        await CaricaVisita(v.IDVisita);
    } else {
        // Se stavamo facendo una nuova visita e annulliamo, torniamo all'ultimo record valido
        if (idPrecedente > 0) {
            await CaricaVisita(idPrecedente);
            indiceCorrente = listaIdVisite.IndexOf(idPrecedente);
        } else {
            await Nuovo();
        }
    }
}

    private async Task Elimina() {
        if (!await JS.InvokeAsync<bool>("confirm", "Eliminare definitivamente questa visita?")) return;
        using var db = new SqlConnection(conn);
        await db.ExecuteAsync("DELETE FROM Visite WHERE IDVisita = @id", new { id = v.IDVisita });
        await CaricaListaId();
        if (listaIdVisite.Any()) await CaricaVisita(listaIdVisite.Last());
        else await Nuovo();
        await ShowToast("Visita eliminata.");
    }

    private async Task Prev() { if (await CheckModificheRealmenteFatte() && indiceCorrente > 0) { indiceCorrente--; await CaricaVisita(listaIdVisite[indiceCorrente]); } }
    private async Task Next() { if (await CheckModificheRealmenteFatte() && indiceCorrente < listaIdVisite.Count - 1) { indiceCorrente++; await CaricaVisita(listaIdVisite[indiceCorrente]); } }
    
    private async Task CheckAndGoHome() { if (await CheckModificheRealmenteFatte()) Nav.NavigateTo("/"); }

    private async Task CaricaClientiVicini() {
        if (clienteSelezionato == null) return;
        using var db = new SqlConnection(conn);
        if (tipoFiltroGiro == "provincia")
            clientiVicini = (await db.QueryAsync<Cliente>("SELECT * FROM Clienti WHERE Prov_Legale = @p AND IdCliente <> @id", new { p = clienteSelezionato.Prov_Legale, id = clienteSelezionato.IdCliente })).ToList();
        else if (tipoFiltroGiro == "comune")
            clientiVicini = (await db.QueryAsync<Cliente>("SELECT * FROM Clienti WHERE Citta_Legale = @c AND IdCliente <> @id", new { c = clienteSelezionato.Citta_Legale, id = clienteSelezionato.IdCliente })).ToList();
        else if (tipoFiltroGiro == "distanza" && clienteSelezionato.Lat.HasValue) {
            var tutti = (await db.QueryAsync<Cliente>("SELECT * FROM Clienti WHERE Lat IS NOT NULL AND IdCliente <> @id", new { id = clienteSelezionato.IdCliente })).ToList();
            clientiVicini = tutti.Where(c => CalcolaKM(clienteSelezionato.Lat.Value, clienteSelezionato.Lon.Value, c.Lat.Value, c.Lon.Value) <= 50).ToList();
        }
    }

    private double CalcolaKM(double lat1, double lon1, double lat2, double lon2) {
        var dLat = (lat2 - lat1) * Math.PI / 180;
        var dLon = (lon2 - lon1) * Math.PI / 180;
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) + Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180) * Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
        return 6371 * (2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a)));
    }

    private async Task OnFiltroGiroChanged(ChangeEventArgs e) { tipoFiltroGiro = e.Value.ToString(); await CaricaClientiVicini(); }
    private async Task SelezionaDaGiro(int id) { if (await CheckModificheRealmenteFatte()) { v.IDCliente = id; await AlCambioCliente(); } }
    private async Task NavigaWaze(Cliente c) 
{
    string ricerca = $"{c.Ind_legale}, {c.Citta_Legale}";
    
    // Usando "waze://" si tenta di aprire direttamente l'app installata
    string url = $"waze://?q={Uri.EscapeDataString(ricerca)}&navigate=yes";

    try 
    {
        await JS.InvokeVoidAsync("open", url, "_self");
    }
    catch 
    {
        // Se l'app non è installata o il protocollo fallisce, 
        // puoi usare il fallback standard che apre il web o l'app se disponibile
        string fallbackUrl = $"https://waze.com/ul?q={Uri.EscapeDataString(ricerca)}&navigate=yes";
        await JS.InvokeVoidAsync("open", fallbackUrl, "_blank");
    }
}
    private async Task EseguiRicerca() { 
        var cl = clienti.FirstOrDefault(c => c.RagSociale.Contains(testoRicerca, StringComparison.OrdinalIgnoreCase)); 
        if (cl != null && await CheckModificheRealmenteFatte()) { v.IDCliente = cl.IdCliente; await AlCambioCliente(); } 
    }
    private async Task CercaEnter(KeyboardEventArgs e) { if (e.Key == "Enter") await EseguiRicerca(); }
    private async Task ShowToast(string msg) { testoNotifica = msg; mostraMessaggio = true; StateHasChanged(); await Task.Delay(3000); mostraMessaggio = false; StateHasChanged(); }
}
