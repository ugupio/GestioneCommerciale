@page "/nuova-visita"
@rendermode InteractiveServer
@using Microsoft.Data.SqlClient
@using Dapper
@using GestioneCommerciale.Models
@using System.Text.Json
@using System.Globalization
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .win-form { background-color: #f0f0f0; font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 11px; border: 1px solid #999; padding: 5px; min-width: 1150px; color: #333; position: relative; min-height: 98vh; }
    .win-header { background: #005a9e; color: white; padding: 3px 8px; font-weight: bold; margin: -5px -5px 5px -5px; font-size: 12px; }
    .win-group { border: 1px solid #c0c0c0; background: #fff; padding: 8px; margin-bottom: 5px; }
    .win-label { font-weight: 500; color: #333; padding-right: 5px; white-space: nowrap; text-align: right; font-size: 10.5px; }
    .win-input { border: 1px solid #ccc; padding: 1px 4px; height: 21px; width: 100%; font-size: 11px; }
    .toolbar-container { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 5px; background: #fdfdfd; border: 1px solid #c0c0c0; margin-bottom: 5px; }
    .win-btn { background: #e1e1e1; border: 1px solid #adadad; padding: 0 15px; color: black; font-size: 11px; height: 72px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; min-width: 85px; text-decoration:none; }
    .win-btn:hover { background: #e5f1fb; border-color: #0078d7; }
    .section-title { font-weight: bold; color: #005a9e; border-bottom: 1px solid #ddd; margin-bottom: 8px; font-size: 10px; text-transform: uppercase; }
    .toast-msg { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 12px 30px; border-radius: 3px; z-index: 9999; box-shadow: 0 5px 15px rgba(0,0,0,0.4); border-left: 5px solid #005a9e; font-size: 13px; }
    .vicini-box { font-size: 10px; border-bottom: 1px solid #eee; padding: 4px 0; display: flex; justify-content: space-between; align-items: center; }
    .btn-waze-sm { background: #333; color: white; border: none; padding: 2px 5px; cursor: pointer; border-radius: 3px; font-size: 12px; }
</style>

<div class="win-form">
    <div class="win-header">Gestione Visite Professional - CRM GestAgenti by Riccardo Gucci soft.</div>

    <!-- TOOLBAR -->
    <div class="toolbar-container">
        <div style="display:flex; gap:5px;">
            <button class="win-btn" @onclick="CheckAndGoHome">🏠 Home</button>
            <button class="win-btn" @onclick="Prev" disabled="@(indiceCorrente <= 0)">◀ Prec.</button>
            <button class="win-btn" @onclick="Next" disabled="@(indiceCorrente >= listaIdVisite.Count - 1 || indiceCorrente == -1)">Succ. ▶</button>
        </div>
        
        <div style="flex-grow: 1; max-width: 400px; display:flex; gap:0;">
            <input type="text" class="win-input" style="height:36px; font-size:13px; border-right:none; border-radius: 2px 0 0 2px;" placeholder="Cerca Cliente..." @bind="testoRicerca" @bind:event="oninput" @onkeyup="CercaEnter" />
            <button style="height:36px; width:40px; background:#e1e1e1; border:1px solid #ccc; cursor:pointer; border-radius: 0 2px 2px 0;" @onclick="EseguiRicerca">🔍</button>
        </div>

        <div style="display:flex; gap:5px;">
            <button class="win-btn" @onclick="Nuovo" style="background:#fff;">📄 Nuova</button>
            <button class="win-btn" @onclick="Annulla" style="background:#f1f1f1;">✖ Annulla</button>
            <button class="win-btn" @onclick="Salva" style="background:#d4edda; border-color:#28a745;">💾 Salva</button>
            @if(v.IDVisita > 0) {
                <button class="win-btn" @onclick="Elimina" style="background:#f8d7da; border-color:#dc3545; color:#721c24;">🗑 Elimina</button>
            }
        </div>
    </div>

    <div style="display: flex; gap: 10px;">
        <!-- DATI VISITA -->
        <div style="flex: 2;">
            <div class="win-group">
                <div class="section-title">Dati Rapporto</div>
                <table style="width:100%; border-spacing: 4px; table-layout: fixed;">
                    <tr>
                        <td style="width:15%" class="win-label">Cliente:</td>
                        <td>
                            <div style="display:flex; gap:2px;">
                                <select class="win-input fw-bold" @bind="v.IDCliente" @bind:after="AlCambioCliente">
                                    <option value="0">-- Seleziona --</option>
                                    @foreach (var cl in clienti) {
                                        <option value="@cl.IdCliente">@cl.RagSociale</option>
                                    }
                                </select>
                                <button type="button" class="btn-waze-sm" title="Naviga" 
                                        disabled="@(clienteSelezionato == null)" @onclick="() => NavigaWaze(clienteSelezionato)">🚙</button>
                            </div>
                        </td>
                        <td style="width:15%" class="win-label">Data Visita:</td>
                        <td><input type="date" class="win-input" @bind="v.DataVisita" /></td>
                    </tr>
                    <tr>
                        <td class="win-label">Motivazione:</td>
                        <td><input type="text" class="win-input" @bind="v.Motivazione" /></td>
                        <td class="win-label">Referente:</td>
                        <td><input type="text" class="win-input" @bind="v.ReferenteIncontrato" /></td>
                    </tr>
                    <tr>
                        <td class="win-label">Esito:</td>
                        <td colspan="3"><textarea class="win-input" style="height:60px; resize:none;" @bind="v.NoteEsito"></textarea></td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- GIRO INTELLIGENTE -->
        <div style="flex: 1;">
            <div class="win-group" style="height: 100%;">
                <div class="section-title">📍 Giro Intelligente</div>
                @if (clienteSelezionato != null)
                {
                    <div style="background:#f9f9f9; padding:5px; border:1px solid #ddd; margin-bottom:8px;">
                        <span style="font-size:9px; font-weight:bold;">CRITERIO:</span>
                        <select class="win-input" @onchange="OnFiltroGiroChanged">
                            <option value="provincia">Stessa Provincia</option>
                            <option value="comune">Stesso Comune</option>
                            <option value="distanza">Raggio 50 KM</option>
                        </select>
                    </div>

                    <div style="max-height: 250px; overflow-y: auto;">
                        @if (!clientiVicini.Any()) { <div class="text-muted italic">Nessun cliente trovato con questo filtro.</div> }
                        @foreach (var vic in clientiVicini) {
                            <div class="vicini-box">
                                <div style="cursor:pointer; flex-grow:1;" @onclick="() => SelezionaDaGiro(vic.IdCliente)">
                                    <b>@vic.RagSociale</b><br /><span>@vic.Citta_Legale</span>
                                </div>
                                <button type="button" class="btn-waze-sm" @onclick="() => NavigaWaze(vic)">🚙</button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private Visita v = new Visita();
    private Cliente clienteSelezionato;
    private List<Cliente> clienti = new();
    private List<Cliente> clientiVicini = new();
    private string tipoFiltroGiro = "provincia";
    private string snapshotOriginale = "";
    private List<int> listaIdVisite = new();
    private int indiceCorrente = -1;
    private int ultimoIndiceValido = 0;
    private string testoRicerca = "";
    private string testoNotifica = "";
    private bool mostraMessaggio = false;
    private string conn = @"Server=.\SQLEXPRESS;Database=GestAgenti;Trusted_Connection=True;TrustServerCertificate=True;";

    protected override async Task OnInitializedAsync() {
        using var db = new SqlConnection(conn);
        clienti = (await db.QueryAsync<Cliente>("SELECT * FROM Clienti ORDER BY RagSociale")).ToList();
        await RinfrescaListaID();
        if (listaIdVisite.Any()) { indiceCorrente = 0; await CaricaVisita(listaIdVisite[indiceCorrente]); } 
        else { ResetNuovo(); }
    }

    private bool IsDirty() => snapshotOriginale != JsonSerializer.Serialize(v);

    private async Task CaricaVisita(int id) {
        using var db = new SqlConnection(conn);
        v = await db.QueryFirstOrDefaultAsync<Visita>("SELECT * FROM Visite WHERE IDVisita = @id", new { id });
        snapshotOriginale = JsonSerializer.Serialize(v);
        if (indiceCorrente != -1) ultimoIndiceValido = indiceCorrente;
        await AlCambioCliente();
    }

    private async Task AlCambioCliente() {
        clienteSelezionato = clienti.FirstOrDefault(c => c.IdCliente == v.IDCliente);
        await ApplicaFiltroGiro();
    }

    private async Task OnFiltroGiroChanged(ChangeEventArgs e) {
        tipoFiltroGiro = e.Value?.ToString() ?? "provincia";
        await ApplicaFiltroGiro();
    }

    private async Task ApplicaFiltroGiro() {
        if (clienteSelezionato == null) { clientiVicini.Clear(); return; }
        using var db = new SqlConnection(conn);
        
        if (tipoFiltroGiro == "provincia") {
            clientiVicini = (await db.QueryAsync<Cliente>("SELECT TOP 10 * FROM Clienti WHERE Prov_Legale=@p AND IdCliente<>@id", new { p=clienteSelezionato.Prov_Legale, id=clienteSelezionato.IdCliente })).ToList();
        } 
        else if (tipoFiltroGiro == "comune") {
            clientiVicini = (await db.QueryAsync<Cliente>("SELECT TOP 10 * FROM Clienti WHERE Citta_Legale=@c AND IdCliente<>@id", new { c=clienteSelezionato.Citta_Legale, id=clienteSelezionato.IdCliente })).ToList();
        }
        else if (tipoFiltroGiro == "distanza") {
            if (clienteSelezionato.Lat == null || clienteSelezionato.Lon == null) {
                clientiVicini.Clear();
                await Notifica("Coordinate cliente selezionato assenti!");
                return;
            }
            // Query con CAST e tolleranza matematica migliorata
            string sql = @"SELECT TOP 10 * FROM Clienti 
                           WHERE IdCliente <> @id AND Lat IS NOT NULL AND Lon IS NOT NULL
                           AND (6371 * acos(p1.val)) < 50
                           FROM (SELECT (sin(radians(CAST(@lat AS FLOAT))) * sin(radians(Lat)) + cos(radians(CAST(@lat AS FLOAT))) * cos(radians(Lat)) * cos(radians(Lon) - radians(CAST(@lon AS FLOAT)))) as val) p1
                           WHERE p1.val BETWEEN -1 AND 1";
            
            // Per semplicità usiamo una versione più diretta ma protetta
            string sqlDirect = @"SELECT TOP 10 * FROM Clienti WHERE IdCliente <> @id AND Lat IS NOT NULL 
                AND (6371 * acos(CASE WHEN (sin(radians(@lat))*sin(radians(Lat)) + cos(radians(@lat))*cos(radians(Lat))*cos(radians(Lon-@lon))) > 1 THEN 1 ELSE (sin(radians(@lat))*sin(radians(Lat)) + cos(radians(@lat))*cos(radians(Lat))*cos(radians(Lon-@lon))) END)) < 50";
            
            clientiVicini = (await db.QueryAsync<Cliente>(sqlDirect, new { lat = (double)clienteSelezionato.Lat, lon = (double)clienteSelezionato.Lon, id = clienteSelezionato.IdCliente })).ToList();
        }
        StateHasChanged();
    }

    private async Task SelezionaDaGiro(int id) {
        if (IsDirty() && !await JS.InvokeAsync<bool>("confirm", "Modifiche pendenti. Cambiare?")) return;
        v.IDCliente = id;
        await AlCambioCliente();
    }

    private void ResetNuovo() {
        v = new Visita { DataVisita = DateTime.Now, TemperaturaCliente = 3, IDCliente = 0, StatoVisita = "Eseguita", NoteEsito="", Motivazione="", ReferenteIncontrato="" };
        snapshotOriginale = JsonSerializer.Serialize(v);
        clienteSelezionato = null;
        clientiVicini.Clear();
        indiceCorrente = -1;
        StateHasChanged();
    }

    private async Task Nuovo() { if (IsDirty() && !await JS.InvokeAsync<bool>("confirm", "Modifiche pendenti. Perderle?")) return; ResetNuovo(); }

    private async Task Annulla() {
        if (indiceCorrente == -1 && !IsDirty()) { await TornaAUltima(); return; }
        if (IsDirty()) {
            if (!await JS.InvokeAsync<bool>("confirm", "Annullare?")) return;
            if (indiceCorrente == -1) await TornaAUltima();
            else await CaricaVisita(v.IDVisita);
        }
    }

    private async Task TornaAUltima() { if (listaIdVisite.Any()) { indiceCorrente = ultimoIndiceValido; await CaricaVisita(listaIdVisite[indiceCorrente]); } }

    private async Task Salva() {
        if (v.IDCliente == 0) { await Notifica("Seleziona cliente!"); return; }
        using var db = new SqlConnection(conn);
        try {
            if (v.IDVisita == 0) {
                string sql = @"INSERT INTO Visite (IDCliente, DataVisita, StatoVisita, Motivazione, ReferenteIncontrato, NoteEsito, TemperaturaCliente, RichiedeSeguito, DataProssimoContatto) 
                               OUTPUT INSERTED.IDVisita VALUES (@IDCliente, @DataVisita, @StatoVisita, @Motivazione, @ReferenteIncontrato, @NoteEsito, @TemperaturaCliente, @RichiedeSeguito, @DataProssimoContatto)";
                v.IDVisita = await db.QuerySingleAsync<int>(sql, v);
                await RinfrescaListaID();
                indiceCorrente = listaIdVisite.IndexOf(v.IDVisita);
            } else {
                string sql = @"UPDATE Visite SET IDCliente=@IDCliente, DataVisita=@DataVisita, StatoVisita=@StatoVisita, Motivazione=@Motivazione, 
                               ReferenteIncontrato=@ReferenteIncontrato, NoteEsito=@NoteEsito, TemperaturaCliente=@TemperaturaCliente, 
                               RichiedeSeguito=@RichiedeSeguito, DataProssimoContatto=@DataProssimoContatto WHERE IDVisita=@IDVisita";
                await db.ExecuteAsync(sql, v);
            }
            snapshotOriginale = JsonSerializer.Serialize(v);
            await Notifica("Salvato!");
        } catch (Exception ex) { await Notifica("Errore: " + ex.Message); }
    }

    private async Task Prev() { if (indiceCorrente > 0) { indiceCorrente--; await CaricaVisita(listaIdVisite[indiceCorrente]); } }
    private async Task Next() { if (indiceCorrente < listaIdVisite.Count - 1) { indiceCorrente++; await CaricaVisita(listaIdVisite[indiceCorrente]); } }
    private async Task RinfrescaListaID() { using var db = new SqlConnection(conn); listaIdVisite = (await db.QueryAsync<int>("SELECT IDVisita FROM Visite ORDER BY DataVisita DESC")).ToList(); }
    private async Task Elimina() { if (!await JS.InvokeAsync<bool>("confirm", "Eliminare?")) return; using var db = new SqlConnection(conn); await db.ExecuteAsync("DELETE FROM Visite WHERE IDVisita=@id", new { id = v.IDVisita }); await RinfrescaListaID(); if (listaIdVisite.Any()) { indiceCorrente = 0; await CaricaVisita(listaIdVisite[0]); } else ResetNuovo(); }
    private async Task EseguiRicerca() { if (string.IsNullOrWhiteSpace(testoRicerca)) return; using var db = new SqlConnection(conn); var trovato = await db.QueryFirstOrDefaultAsync<int?>("SELECT TOP 1 V.IDVisita FROM Visite V JOIN Clienti C ON V.IDCliente = C.IdCliente WHERE C.RagSociale LIKE @t ORDER BY V.DataVisita DESC", new { t = "%" + testoRicerca + "%" }); if (trovato.HasValue) { indiceCorrente = listaIdVisite.IndexOf(trovato.Value); await CaricaVisita(trovato.Value); } }
    private void CercaEnter(KeyboardEventArgs e) { if (e.Key == "Enter") EseguiRicerca(); }
    private async Task CheckAndGoHome() { if (IsDirty() && !await JS.InvokeAsync<bool>("confirm", "Uscire?")) return; Nav.NavigateTo("/"); }
    private async Task Notifica(string m) { testoNotifica = m; mostraMessaggio = true; StateHasChanged(); await Task.Delay(2000); mostraMessaggio = false; StateHasChanged(); }
    
    private async Task NavigaWaze(Cliente target) {
        if (target?.Lat == null || target?.Lon == null) { await Notifica("Coordinate GPS assenti!"); return; }
        // Forzo il punto come separatore decimale
        string lat = target.Lat.Value.ToString("F6", CultureInfo.InvariantCulture);
        string lon = target.Lon.Value.ToString("F6", CultureInfo.InvariantCulture);
        await JS.InvokeVoidAsync("open", $"waze://?ll={lat},{lon}&navigate=yes", "_blank");
    }
}
