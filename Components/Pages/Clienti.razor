    private async Task Nuovo() {
    // 1. Controllo standard "Visite": se ci sono modifiche, chiedi conferma
    if (IsDirty() && !await JS.InvokeAsync<bool>("confirm", "Modifiche pendenti. Perderle?")) 
        return;
    
    // 2. Resetta l'interfaccia
    ResetNuovo();
}
    
    private async Task Annulla() {
    // 4. Se ci sono modifiche, chiedi conferma
    if (IsDirty()) {
        if (await JS.InvokeAsync<bool>("confirm", "Annullare le modifiche non salvate?")) {
            if (indiceCorrente == -1) ResetNuovo();
            else await CaricaCliente(listaIdClienti[indiceCorrente]);
        }
    } else {
        // 5. Se NON è sporco e siamo in modalità "Nuovo", torna semplicemente all'ultimo record
        if (indiceCorrente == -1 && listaIdClienti.Any()) {
            indiceCorrente = 0;
            await CaricaCliente(listaIdClienti[indiceCorrente]);
        }
    }
    }


    private async Task Elimina() { 
        if (!await JS.InvokeAsync<bool>("confirm", "Eliminare definitivamente?")) return; 
        using var db = new SqlConnection(conn); 
        await db.ExecuteAsync("DELETE FROM Clienti WHERE IdCliente=@id", new { id = c.IdCliente }); 
        await RinfrescaListaID(); 
        if (listaIdClienti.Any()) await CaricaCliente(listaIdClienti[0]); 
        else ResetNuovo(); 
    }

    private async Task Prev() {
    // 1. Prima di tutto, controlla se ci sono modifiche, a prescindere dall'indice
    if (IsDirty()) {
        if (!await JS.InvokeAsync<bool>("confirm", "Ci sono modifiche non salvate. Vuoi scartarle e continuare?")) {
            return; // L'utente ha annullato, restiamo qui
        }
    }

    // 2. Solo dopo il controllo modifiche, verifichiamo la posizione
    if (indiceCorrente > 0) { 
        indiceCorrente--; 
        await CaricaCliente(listaIdClienti[indiceCorrente]); 
    } 
    else {
        // Se siamo qui, l'utente ha accettato di scartare le modifiche (o non ce n'erano)
        // ma non ci sono record precedenti.
        await Notifica("Sei già sul primo record.");
        
        // OPZIONALE: Se era "sporco", ricarichiamo il record attuale 
        // per resettare i campi ai valori originali del DB
        if (indiceCorrente != -1) {
            await CaricaCliente(listaIdClienti[indiceCorrente]);
        }
    }
}



    private async Task Next() {
    if (IsDirty() && !await JS.InvokeAsync<bool>("confirm", "Modifiche non salvate. Continuare?")) return;
    if (indiceCorrente < listaIdClienti.Count - 1) { 
        indiceCorrente++; 
        await CaricaCliente(listaIdClienti[indiceCorrente]); 
    } 
    }

    // Tasto Ricerca (Eseguita con la lente o premendo Invio)
    private async Task EseguiRicerca() { 
        if (string.IsNullOrWhiteSpace(testoRicerca)) return; 
        if (IsDirty() && !await JS.InvokeAsync<bool>("confirm", "Modifiche pendenti. Cercare un altro cliente e perderle?")) return;

        using var db = new SqlConnection(conn); 
        var trovato = await db.QueryFirstOrDefaultAsync<int?>("SELECT IdCliente FROM Clienti WHERE RagSociale LIKE @t", new { t = "%" + testoRicerca + "%" }); 
        if (trovato.HasValue) { 
        indiceCorrente = listaIdClienti.IndexOf(trovato.Value); 
        await CaricaCliente(trovato.Value); 
        } else {
        await Notifica("Nessun cliente trovato.");
        }
    }

    private void CercaEnter(KeyboardEventArgs e) { if (e.Key == "Enter") EseguiRicerca(); }
    
