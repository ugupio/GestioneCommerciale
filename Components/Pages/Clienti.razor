    }

    private async Task Notifica(string m) { 
        testoNotifica = m; 
        mostraMessaggio = true; 
        StateHasChanged(); 
        await Task.Delay(2500); 
        mostraMessaggio = false; 
        StateHasChanged(); 
    }

