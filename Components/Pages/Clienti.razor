@page "/anagrafica-clienti"
@rendermode InteractiveServer
@using System.Data.SqlClient
@using Dapper
@using GestioneCommerciale.Models
@using System.Text.Json
@using System.Text.Json.Serialization
@using System.Net.Http
@using System.Globalization
@using System.Data
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IHttpClientFactory ClientFactory
@inject IJSRuntime JSRuntime


<style>
    .win-form { background-color: #f0f0f0; font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 11px; border: 1px solid #999; padding: 5px; min-width: 1150px; color: #333; position: relative; min-height: 98vh; }
    .win-header { background: #005a9e; color: white; padding: 3px 8px; font-weight: bold; margin: -5px -5px 5px -5px; font-size: 12px; }
    .win-group { border: 1px solid #c0c0c0; background: #fff; padding: 8px; margin-bottom: 5px; }
    .win-label { font-weight: 500; color: #333; padding-right: 5px; white-space: nowrap; text-align: right; font-size: 10.5px; }
    .win-input { border: 1px solid #ccc; padding: 1px 4px; height: 21px; width: 100%; font-size: 11px; }
    .section-title { font-weight: bold; color: #005a9e; border-bottom: 1px solid #ddd; margin-bottom: 8px; font-size: 10px; text-transform: uppercase; }
    .toast-msg { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 12px 30px; border-radius: 3px; z-index: 9999; box-shadow: 0 5px 15px rgba(0,0,0,0.4); border-left: 5px solid #28a745; font-size: 13px; }
    /* Tab larghi e alti per il touch */
    .win-tabs { display: flex; background: #e1e1e1; border: 1px solid #999; margin-top: 10px; }
    .win-tab { 
        padding: 12px 20px; 
        cursor: pointer; 
        background: #d1d1d1; 
        border-right: 1px solid #999;
        font-weight: bold;
        flex-grow: 1; /* I tab si spartiscono lo spazio */
        text-align: center;
    }
    .win-tab.active { background: #fff; border-bottom: 3px solid #005a9e; color: #005a9e; }
    
    .win-tab-content { 
        border: 1px solid #999; 
        border-top: none; 
        background: #fff; 
        min-height: 200px;
        padding: 5px;
    }

    /* Ottimizzazione tabelle interne per mobile */
    .tab-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .tab-table th { background: #f0f0f0; padding: 8px; border: 1px solid #ccc; text-align: left; }
    .tab-

    .row-clickable { cursor: pointer; transition: background 0.2s; }
    .row-clickable:hover { background-color: #d1e8ff !important; }

     /* --- NUOVO DESIGN PREMIUM TALL --- */
    .btn-comando-ordine {
        height: 90px !important;
        min-width: 95px !important;
        display: inline-flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 5px !important;
        padding: 10px !important;
        background: #ffffff !important;
        color: #1e3c72 !important;
        font-weight: bold !important;
        border: 2px solid #ffffff !important;
        border-radius: 12px !important;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;
        transition: all 0.2s ease-in-out !important;
        cursor: pointer !important;
        text-transform: uppercase;
        font-size: 10px !important;
        user-select: none !important;
    }

    .btn-comando-ordine:hover {
        background: #00d2ff !important;
        color: white !important;
        border-color: #00d2ff !important;
        transform: scale(1.05) !important;
        box-shadow: 0 0 20px rgba(0, 210, 255, 0.6) !important;
    }

    .btn-comando-ordine span:first-child { font-size: 2rem !important; pointer-events: none !important; }
    .btn-start-nav { background: #f8f9fa !important; border-color: #dee2e6 !important; }
    .btn-start-verde { background: #d4edda !important; border-color: #28a745 !important; }
    .btn-start-rosso { background: #f8d7da !important; border-color: #dc3545 !important; color: #721c24 !important; }

    /* Barra di Ricerca Premium */
    .search-wrapper-premium {
        display: flex; align-items: center; background: white;
        border: 2px solid #ffffff; border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1); height: 90px; overflow: hidden;
    }
    .search-input-premium {
        border: none !important; padding: 0 20px !important; font-size: 16px !important;
        flex-grow: 1; outline: none !important; height: 100%; color: #1e3c72;
    }
    .search-btn-premium {
        background: #f8f9fa; border: none; width: 70px; height: 100%;
        cursor: pointer; font-size: 1.5rem; border-left: 1px solid #eee;
    }   

    /* Contenitore riga: allinea etichetta e input */
    .form-row {
        display: flex;
        align-items: center;
        margin-bottom: 4px; /* Spazio compatto tra le righe */
        gap: 10px;
    }

    /* Etichetta fissa: IL SEGRETO PER L'ALLINEAMENTO */
    .lbl-fixed {
        width: 100px; /* Tutte le etichette larghe uguali */
        text-align: right;
        font-weight: bold;
        color: #005a9e;
        font-size: 10.5px;
        flex-shrink: 0;
    }

    /* Input che riempie lo spazio */
    .input-flex {
        flex-grow: 1;
    }

    /* Sotto-gruppi per mettere più campi sulla stessa riga */
    .form-col {
        display: flex;
        align-items: center;
        gap: 5px;
        flex: 1;
    }

	.win-row-compact {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 3px; /* Spazio strettissimo tra le righe */
    }
    .lbl-fixed {
        width: 75px; /* Etichette ancora più strette */
        text-align: right;
        font-weight: bold;
        color: #005a9e;
        font-size: 10.5px;
        flex-shrink: 0;
    }
    /* Classi per larghezze fisse dei campi corti */
    .w-cap { width: 55px !important; flex-grow: 0 !important; }
    .w-prov { width: 35px !important; flex-grow: 0 !important; }
    .w-piva { width: 120px !important; flex-grow: 0 !important; }
    .w-sconto { width: 60px !important; flex-grow: 0 !important; }

    .w-tel { width: 100px !important; flex-grow: 0 !important; }
    .w-gps { width: 90px !important; flex-shrink: 0 !important; }
    .w-fiscale { width: 140px !important; flex-shrink: 0 !important; }
    .w-email { flex-grow: 1.5 !important; } /* Email ha spazio ma non infinito */
    .win-check-label { font-size: 10.5px; cursor: pointer; display: flex; align-items: center; gap: 4px; }
    .w-abi { width: 50px !important; flex-grow: 0 !important; }
    .w-sdi { width: 70px !important; flex-grow: 0 !important; }
    .w-iban { flex-grow: 2 !important; }
    .w-prev { width: 85px !important; flex-grow: 0 !important; color: #005a9e; font-weight: bold; }
</style>

<div class="win-form">
    <div class="win-header">Anagrafica Clienti Professional - CRM GestAgenti by Riccardo Gucci soft.</div>
    
    <div class="toolbar-container" style="background: transparent; border: none; align-items: flex-start; gap: 15px;">
    
    <!-- BARRA COMANDI ALLINEATA IN RIGA -->
<div style="display:flex; flex-wrap: nowrap; align-items: stretch; gap:10px; margin-bottom: 20px; width: 100%;">
    
    <!-- GRUPPO NAVIGAZIONE -->
    <div style="display:flex; gap:5px; flex-shrink: 0;">
        <button class="btn-comando-ordine btn-start-nav" @onclick="CheckAndGoHome"><span>🏠</span><span>HOME</span></button>
        <button class="btn-comando-ordine btn-start-nav" @onclick="Prev" disabled="@(indiceCorrente <= 0)"><span>◀</span><span>PREC.</span></button>
        <button class="btn-comando-ordine btn-start-nav" @onclick="Next"><span>▶</span><span>SUCC.</span></button>
    </div>

    <!-- RICERCA (Si allunga per riempire lo spazio) -->
    <div style="flex-grow: 1; min-width: 200px;">
        <div class="search-wrapper-premium" style="height: 100%;">
            <input type="text" class="search-input-premium" placeholder="Cerca Ragione Sociale..." @bind="testoRicerca" @bind:event="oninput" @onkeyup="CercaEnter" />
            <button class="search-btn-premium" @onclick="EseguiRicerca">🔍</button>
        </div>
    </div>

    <!-- GRUPPO AZIONI -->
    <div style="display:flex; gap:5px; flex-shrink: 0;">
        <button class="btn-comando-ordine" @onclick="Nuovo"><span>👤➕</span><span>NUOVO</span></button>
        <button class="btn-comando-ordine" @onclick="Annulla"><span>✖</span><span>ANNULLA</span></button>
        <button class="btn-comando-ordine btn-start-verde" @onclick="Salva"><span>💾</span><span>SALVA</span></button>
        @if(c.IdCliente > 0) {
            <button class="btn-comando-ordine btn-start-rosso" @onclick="Elimina"><span>🗑️</span><span>ELIMINA</span></button>
        }
    </div>

</div>
</div>

    <div class="win-group">
    <div class="section-title">Dati Anagrafici e Politiche Sconti</div>
    
    <!-- RIGA 1: Ragione Sociale, Referente e P.IVA -->
    <div class="win-row-compact">
        <label class="lbl-fixed">Rag. Soc.:</label>
        <input type="text" class="win-input fw-bold" style="flex-grow: 2;" @bind="c.RagSociale" />
        
        <label class="lbl-fixed" style="width: 60px;">Ref.:</label>
        <input type="text" class="win-input" style="flex-grow: 1;" @bind="c.Referente" />
                        
        <label class="lbl-fixed" style="width: 70px; color: #d63384;">Sc. Prof %:</label>
        <input type="number" class="win-input w-sconto text-end fw-bold" @bind="c.ScontoProfili" />
    </div>

    <!-- RIGA 2: Indirizzo, Città, CAP, Prov e Sconto Acc -->
    <div class="win-row-compact">
        <label class="lbl-fixed">Indirizzo:</label>
        <input type="text" class="win-input" style="flex-grow: 2;" @bind="c.Ind_legale" />
        
        <label class="lbl-fixed" style="width: 60px;">Città:</label>
        <input type="text" class="win-input" style="flex-grow: 1;" @bind="c.Citta_Legale" />
        
        <label class="lbl-fixed" style="width: 30px;">CAP:</label>
        <input type="text" class="win-input w-cap" maxlength="5" @bind="c.CAP_Legale" />
        
        <label class="lbl-fixed" style="width: 15px;">Pr:</label>
        <input type="text" class="win-input w-prov" maxlength="2" @bind="c.Prov_Legale" />
        
        <label class="lbl-fixed" style="width: 70px; color: #d63384;">Sc. Acc %:</label>
        <input type="number" class="win-input w-sconto text-end fw-bold" @bind="c.ScontoAccessori" />
    </div>
</div>



    <!-- SEZIONE 2: CONTATTI E GPS -->
    <div class="win-group">
    <div class="section-title">Contatti, Dati Fiscali e Coordinate Bancarie</div>
    
    <!-- RIGA 1: Email, Tel, Fax, P.IVA e Cod. Fiscale -->
    <div class="win-row-compact">
        <label class="lbl-fixed">Email:</label>
        <input type="text" class="win-input w-email" @bind="c.Email" />
        <label class="lbl-fixed" style="width: 30px;">Tel:</label>
        <input type="text" class="win-input w-tel" @bind="c.Telefono" />
        <label class="lbl-fixed" style="width: 30px;">Fax:</label>
        <input type="text" class="win-input w-tel" @bind="c.Fax" />
        <label class="lbl-fixed" style="width: 40px;">P.IVA:</label>
        <input type="text" class="win-input w-piva" @bind="c.PIva" />
        <label class="lbl-fixed" style="width: 40px;">C.F.:</label>
        <input type="text" class="win-input w-fiscale" @bind="c.CodFiscale" />
    </div>

    <!-- RIGA 2: Cellulari, GPS e Opzioni -->
    <div class="win-row-compact">
        <label class="lbl-fixed">Cell 1:</label>
        <input type="text" class="win-input w-tel" @bind="c.Cel1" />
        <label class="lbl-fixed" style="width: 40px;">Cell 2:</label>
        <input type="text" class="win-input w-tel" @bind="c.Cel2" />
        <label class="lbl-fixed" style="width: 60px; color: #dc3545;">Lat:</label>
        <input type="text" class="win-input w-gps text-center" @bind="displayLat" />
        <label class="lbl-fixed" style="width: 30px; color: #dc3545;">Lon:</label>
        <input type="text" class="win-input w-gps text-center" @bind="displayLon" />
        <div style="display: flex; gap: 15px; margin-left: 20px; border-left: 1px solid #ccc; padding-left: 15px;">
            <label class="win-check-label"><input type="checkbox" @bind="c.Carrello" /> Carrello</label>
            <label class="win-check-label"><input type="checkbox" @bind="c.ScaricoAgevole" /> Scarico</label>
        </div>
    </div>

    <!-- RIGA 3: Banca, Agenzia, ABI, CAB, SDI e Previsione Annua -->
    <div class="win-row-compact" style="border-top: 1px dashed #ddd; padding-top: 4px; margin-top: 4px;">
        <label class="lbl-fixed">Banca:</label>
        <input type="text" class="win-input" style="flex-grow: 1.5;" @bind="c.Banca" />
        <label class="lbl-fixed" style="width: 50px;">Agenzia:</label>
        <input type="text" class="win-input" style="flex-grow: 1;" @bind="c.Agenzia" />
        <label class="lbl-fixed" style="width: 30px;">ABI:</label>
        <input type="text" class="win-input w-abi" @bind="c.ABI" />
        <label class="lbl-fixed" style="width: 30px;">CAB:</label>
        <input type="text" class="win-input w-abi" @bind="c.CAB" />
        <label class="lbl-fixed" style="width: 30px;">SDI:</label>
        <input type="text" class="win-input w-sdi" @bind="c.SDI" />
        <label class="lbl-fixed" style="width: 65px; color: #28a745;">Prev. Ann. €:</label>
        <input type="number" class="win-input w-prev text-end" @bind="c.PrevisioneAnnuo" />
    </div>

    <!-- RIGA 4: IBAN e Pagamenti -->
    <div class="win-row-compact">
        <label class="lbl-fixed">IBAN:</label>
        <input type="text" class="win-input w-iban" @bind="c.IBAN" />
        <label class="lbl-fixed" style="width: 60px;">Pag. Prop:</label>
        <input type="text" class="win-input" style="flex-grow: 1;" @bind="c.PagProposto" />
        <label class="lbl-fixed" style="width: 60px;">Pag. Acc:</label>
        <input type="text" class="win-input" style="flex-grow: 1;" @bind="c.PagAccettato" />
    </div>

    <!-- RIGA 5: Annotazioni -->
    <div class="win-row-compact">
        <label class="lbl-fixed">Annotazioni:</label>
        <input type="text" class="win-input" @bind="c.Annotazioni" />
    </div>
    <!-- RIGA 6: Logica Commerciale (Zona e Frequenza) -->
        <div class="win-row-compact">
            <label class="lbl-fixed">Zona Operativa:</label>
            <select class="win-input" @bind="c.IdZona" style="flex: 2; height: 24px; padding: 0 5px;">
            <option value="0">-- SELEZIONA ZONA --</option>
                @foreach (var z in ListeZone) {
                    <option value="@z.IdZona">@z.NomeZona</option>
                }
            </select>

    <label class="lbl-fixed" style="margin-left: 20px;">Frequenza (gg):</label>
    <input type="number" class="win-input" @bind="c.FrequenzaVisitaGg" style="flex: 1;" />
</div>



        <!-- AREA DETTAGLI CORRELATI -->
<div class="win-tabs">
    <div class="win-tab @(activeTab == "ordini" ? "active" : "")" @onclick='() => activeTab = "ordini"'>🛒 ORDINI</div>
    <div class="win-tab @(activeTab == "resi" ? "active" : "")" @onclick='() => activeTab = "resi"'>📦 RESI</div>
    <div class="win-tab @(activeTab == "visite" ? "active" : "")" @onclick='() => activeTab = "visite"'>📅 VISITE</div>
</div>

<div class="win-tab-content">
    @if (activeTab == "ordini") 
    {
        <!-- RIEPILOGO ORDINI -->
        <div style="background: #e1e1e1; padding: 5px 10px; border: 1px solid #999; border-bottom: none; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-weight: bold; color: #005a9e;">📦 STORICO ORDINI</span>
            <div style="font-size: 12px;">
                <span class="me-3">Documenti: <strong>@listaOrdiniCliente.Count</strong></span>
                <span>Volume Affari: <strong style="color: #28a745; font-size: 14px;">@totaleOrdiniCliente.ToString("C2")</strong></span>
            </div>
        </div>
        <table class="tab-table">
            <thead>
                <tr style="background:#f0f0f0"><th>Data</th><th>Numero</th><th>Rif. Cliente</th><th class="text-end">Totale</th></tr>
            </thead>
            <tbody>
                @foreach (var o in listaOrdiniCliente) {
                    <tr @ondblclick='() => ApriDocumento((int)(o.IDOrdine ?? 0), "ORDINE")' class="row-clickable">
                        <td>@string.Format("{0:dd/MM/yyyy}", (object)o.DataOrdine)</td>
                        <td>@(((object)o.NumeroDocumento)?.ToString() ?? "")</td>
                        <td>@(((object)o.RiferimentoCliente)?.ToString() ?? "-")</td>
                        <td class="text-end">@(((object)o.TotaleImponibile)?.ToString() ?? "0") €</td>
                    </tr>
                }
            </tbody>
        </table>
    } 
    else if (activeTab == "resi") 
    {
        <!-- RIEPILOGO RESI -->
        <table class="tab-table">
            <thead>
                <tr style="background:#f0f0f0"><th>Data</th><th>Causale/Nota</th><th class="text-end">Q.tà</th></tr>
            </thead>
            <tbody>
                @foreach (var r in listaResiCliente) {
                    <tr @ondblclick='() => ApriDocumento((int)(r.IDReso ?? 0), "RESO")' class="row-clickable">
                        <td>@(((object)r.DataReso)?.ToString() ?? "")</td>
                        <td>@(((object)r.Motivazione)?.ToString() ?? "")</td>
                        <td class="text-end">@(((object)r.Quantita)?.ToString() ?? "0")</td>
                    </tr>
                }
            </tbody>
        </table>
    } 
    else if (activeTab == "visite") 
    {
        <!-- RIEPILOGO VISITE -->
        <table class="tab-table">
            <thead>
                <tr style="background:#f0f0f0"><th>Data</th><th>Stato</th><th>Note</th></tr>
            </thead>
            <tbody>
                @foreach (var v in listaVisiteCliente) {
                   <tr @ondblclick='() => ApriDocumento((int)(v.IDVisita ?? 0), "VISITA")' class="row-clickable">
                        <td>@(((object)v.DataVisita)?.ToString() ?? "")</td>
                        <td>@(((object)v.StatoVisita)?.ToString() ?? "")</td>
                        <td>@(((object)v.Note)?.ToString() ?? "")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
</div>

    @if (mostraMessaggio) { <div class="toast-msg">@testoNotifica</div> }
</div>

@code {
    private Cliente c = new Cliente();
    private string displayLat = "", displayLon = "", snapshotOriginale = "", testoRicerca = "", testoNotifica = "";
    private List<int> listaIdClienti = new();
    private int indiceCorrente = -1;
    private bool mostraMessaggio = false;
    private string conn = @"Server=.\SQLEXPRESS;Database=GestAgenti;Trusted_Connection=True;TrustServerCertificate=True;";
    private bool IsDirty() => snapshotOriginale != JsonSerializer.Serialize(c);
    private string activeTab = "ordini";
    private List<dynamic> listaOrdiniCliente = new();
    private List<dynamic> listaResiCliente = new();
    private List<dynamic> listaVisiteCliente = new();
    private decimal totaleOrdiniCliente;
    private List<Zona> ListeZone = new();




    protected override async Task OnInitializedAsync()
{
    // 1. Carica prima di tutto le zone (servono per i menu a tendina)
    using (IDbConnection db = new SqlConnection(conn))
    {
        ListeZone = (await db.QueryAsync<Zona>("SELECT IdZona, NomeZona FROM Zone ORDER BY NomeZona")).ToList();
    }

    // 2. Prosegue con la logica esistente dei clienti
    await RinfrescaListaID();

    if (listaIdClienti.Any())
    {
        indiceCorrente = 0;
        await CaricaCliente(listaIdClienti[indiceCorrente]);
    }
    else
    {
        ResetNuovo();
    }
}


    
    
    
    private async Task CaricaCliente(int id) {
        using var db = new SqlConnection(conn);
        c = await db.QueryFirstOrDefaultAsync<Cliente>("SELECT * FROM Clienti WHERE IdCliente = @id", new { id });

        // Caricamento coordinate in stringa per la UI
        displayLat = c.Lat?.ToString("F6", CultureInfo.InvariantCulture) ?? "";
        displayLon = c.Lon?.ToString("F6", CultureInfo.InvariantCulture) ?? "";

        snapshotOriginale = JsonSerializer.Serialize(c);
        await CaricaDettagliCorrelati(id);
        StateHasChanged();
    }

    private void ResetNuovo() { 
        c = new Cliente(); 
        displayLat = ""; 
        displayLon = ""; 
        snapshotOriginale = JsonSerializer.Serialize(c); 
        indiceCorrente = -1; 
        StateHasChanged(); 
    }

    private void SincronizzaCoordinate() {
        // Pulizia e parsing sicuro delle coordinate
        string l1 = (displayLat ?? "").Replace(",", ".");
        string l2 = (displayLon ?? "").Replace(",", ".");

        if (float.TryParse(l1, CultureInfo.InvariantCulture, out float f1)) c.Lat = f1; else c.Lat = null;
        if (float.TryParse(l2, CultureInfo.InvariantCulture, out float f2)) c.Lon = f2; else c.Lon = null;
    }

    private async Task Salva() {
    if (string.IsNullOrWhiteSpace(c.RagSociale)) { 
        await Notifica(" Ragione Sociale obbligatoria!"); 
        return; 
    }

    // Se le coordinate sono vuote ma c'è l'indirizzo, prova la geocodifica
    if (string.IsNullOrWhiteSpace(displayLat) && !string.IsNullOrWhiteSpace(c.Ind_legale)) 
        await GeocodificaIndirizzo();
    else 
        SincronizzaCoordinate();

    using var db = new SqlConnection(conn);
    try {
        if (c.IdCliente == 0) {
            // QUERY INSERT COMPLETA (Pagina 12)
            string sql = @"INSERT INTO Clienti (RagSociale, Referente, Ind_legale, Citta_Legale, 
                           CAP_Legale, Prov_Legale, Telefono, Fax, Email, Cel1, Cel2, PIva, CodFiscale, 
                           SDI, Banca, Agenzia, ABI, CAB, IBAN, PagProposto, PagAccettato, 
                           InfoCommerciali, PrevisioneAnnuo, Carrello, ScaricoAgevole, 
                           Annotazioni, ScontoProfili, ScontoAccessori, Lat, Lon, IdZona, FrequenzaVisitaGg) 
                           OUTPUT INSERTED.IdCliente 
                           VALUES (@RagSociale, @Referente, @Ind_legale, @Citta_Legale, 
                           @CAP_Legale, @Prov_Legale, @Telefono, @Fax, @Email, @Cel1, @Cel2, @PIva, @CodFiscale, 
                           @SDI, @Banca, @Agenzia, @ABI, @CAB, @IBAN, @PagProposto, @PagAccettato, 
                           @InfoCommerciali, @PrevisioneAnnuo, @Carrello, @ScaricoAgevole, 
                           @Annotazioni, @ScontoProfili, @ScontoAccessori, @Lat, @Lon, @IdZona, @FrequenzaVisitaGg)";
            
            c.IdCliente = await db.QuerySingleAsync<int>(sql, c);
            await RinfrescaListaID();
            indiceCorrente = listaIdClienti.IndexOf(c.IdCliente);
        } else {
            // QUERY UPDATE COMPLETA (Pagina 13)
            string sql = @"UPDATE Clienti SET RagSociale=@RagSociale, Referente=@Referente, 
                           Ind_legale=@Ind_legale, Citta_Legale=@Citta_Legale, CAP_Legale=@CAP_Legale, 
                           Prov_Legale=@Prov_Legale, Telefono=@Telefono, Fax=@Fax, Email=@Email, 
                           Cel1=@Cel1, Cel2=@Cel2, PIva=@PIva, CodFiscale=@CodFiscale, SDI=@SDI, 
                           Banca=@Banca, Agenzia=@Agenzia, ABI=@ABI, CAB=@CAB, IBAN=@IBAN, 
                           PagProposto=@PagProposto, PagAccettato=@PagAccettato, 
                           InfoCommerciali=@InfoCommerciali, PrevisioneAnnuo=@PrevisioneAnnuo, 
                           Carrello=@Carrello, ScaricoAgevole=@ScaricoAgevole, 
                           Annotazioni=@Annotazioni, ScontoProfili=@ScontoProfili, 
                           ScontoAccessori=@ScontoAccessori, Lat=@Lat, Lon=@Lon, IdZona=@IdZona, FrequenzaVisitaGg=@FrequenzaVisitaGg
                           WHERE IdCliente=@IdCliente";
            
            await db.ExecuteAsync(sql, c);
        }

        // AGGIORNAMENTO SNAPSHOT (Per rendere IsDirty() = false ed evitare popup loop)
        snapshotOriginale = JsonSerializer.Serialize(c);
        
        await Notifica(" Cliente salvato con successo!");
        StateHasChanged();
    } catch (Exception ex) { 
        await Notifica(" Errore DB: " + ex.Message); 
    }
}


    private async Task GeocodificaIndirizzo() {
    try {
        if (string.IsNullOrWhiteSpace(c.Ind_legale) || string.IsNullOrWhiteSpace(c.Citta_Legale)) {
            await Notifica(" Indirizzo o Città mancanti!");
            return;
        }

        await Notifica(" Ricerca coordinate...");
        using var client = new HttpClient();
        client.Timeout = TimeSpan.FromSeconds(10);

        // Parametri puliti
        string token = "pk.41a064476ff914f4e50c47e4f3cf9ebe";
        string queryTesto = $"{c.Ind_legale.Trim()}, {c.Citta_Legale.Trim()}, Italy";

        // COSTRUZIONE URL PROFESSIONALE (Risolve Hostname could not be parsed)
        var builder = new UriBuilder("https://us1.locationiq.com/v1/search");
        var query = System.Web.HttpUtility.ParseQueryString(builder.Query);
        query["key"] = token;
        query["q"] = queryTesto;
        query["format"] = "json";
        query["limit"] = "1";
        builder.Query = query.ToString();

        // builder.Uri contiene l'URL perfettamente formattato
        var resp = await client.GetAsync(builder.Uri);
        
        if (resp.IsSuccessStatusCode) {
            var json = await resp.Content.ReadAsStringAsync();
            var results = JsonSerializer.Deserialize<List<NominatimResult>>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (results != null && results.Any()) {
                // Preleviamo i dati dal primo risultato
                displayLat = results[0].Lat; 
                displayLon = results[0].Lon;
                
                SincronizzaCoordinate();
                await Notifica(" Coordinate ottenute!");
            } else {
                await Notifica(" Nessun risultato trovato.");
            }
        } else {
            await Notifica($" Errore API: {(int)resp.StatusCode}");
        }
    } catch (Exception ex) {
        // Se c'è ancora un errore, lo vedrai qui con dettaglio
        await Notifica(" Errore: " + ex.Message);
    }
    StateHasChanged();
}

