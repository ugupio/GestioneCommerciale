    private async Task CaricaDettagliCorrelati(int idCliente)
{
    using var db = new SqlConnection(conn);
    
    // Carichiamo la lista
    var ordini = (await db.QueryAsync("SELECT * FROM Ordini WHERE IdCliente = @idCliente", new { idCliente })).ToList();
    listaOrdiniCliente = ordini;

    // CALCOLO ROBUSTO:
    // Cicliamo la lista e sommiamo convertendo esplicitamente ogni valore
    totaleOrdiniCliente = 0;
    foreach (var o in ordini)
    {
        // Usiamo Convert.ToDecimal perché il campo nel DB potrebbe essere float o money
        totaleOrdiniCliente += Convert.ToDecimal(o.TotaleImponibile ?? 0);
    }

    // Caricamento altri tab...
    listaResiCliente = (await db.QueryAsync("SELECT * FROM Resi WHERE IdCliente = @idCliente", new { idCliente })).ToList();
    listaVisiteCliente = (await db.QueryAsync("SELECT * FROM Visite WHERE IdCliente = @idCliente", new { idCliente })).ToList();
    
    StateHasChanged(); // Forza l'aggiornamento grafico
}




