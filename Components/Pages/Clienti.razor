@page "/anagrafica-clienti"
@rendermode InteractiveServer
@using Microsoft.Data.SqlClient
@using Dapper
@using GestioneCommerciale.Models
@using Microsoft.AspNetCore.Components
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .win-form { background-color: #f0f0f0; font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 11px; border: 1px solid #999; padding: 5px; min-width: 1150px; color: #333; position: relative; min-height: 98vh; }
    .win-header { background: #005a9e; color: white; padding: 3px 8px; font-weight: bold; margin: -5px -5px 5px -5px; font-size: 12px; }
    .win-group { border: 1px solid #c0c0c0; background: #fff; padding: 8px; margin-bottom: 5px; }
    .win-label { font-weight: 500; color: #333; padding-right: 5px; white-space: nowrap; text-align: right; font-size: 10.5px; }
    .win-input { border: 1px solid #ccc; padding: 1px 4px; height: 21px; width: 100%; font-size: 11px; }
    .win-input:focus { border-color: #0078d7; outline: none; background-color: #faffbd; }
    .toolbar-container { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 5px; background: #fdfdfd; border: 1px solid #c0c0c0; margin-bottom: 5px; }
    .win-btn { background: #e1e1e1; border: 1px solid #adadad; padding: 0 15px; color: black; font-size: 11px; height: 72px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; min-width: 85px; text-decoration:none; }
    .win-btn:hover { background: #e5f1fb; border-color: #0078d7; }
    .section-title { font-weight: bold; color: #005a9e; border-bottom: 1px solid #ddd; margin-bottom: 8px; font-size: 10px; text-transform: uppercase; }
    .toast-msg { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 12px 30px; border-radius: 3px; z-index: 9999; box-shadow: 0 5px 15px rgba(0,0,0,0.4); border-left: 5px solid #28a745; font-size: 13px; }
</style>

<div class="win-form">
    <div class="win-header">Anagrafica Clienti Professional - GestAgenti CRM by Riccardo Gucci soft.</div>

    <!-- TOOLBAR -->
    <div class="toolbar-container">
        <div style="display:flex; gap:5px;">
            <button class="win-btn" @onclick='() => Nav.NavigateTo("/")'>🏠 Home</button>
            <button class="win-btn" @onclick="Prev" disabled="@(indiceCorrente <= 0)">◀ Prec.</button>
            <button class="win-btn" @onclick="Next" disabled="@(indiceCorrente >= listaIdClienti.Count - 1)">Succ. ▶</button>
        </div>
        
        <div style="flex-grow: 1; max-width: 400px; display:flex; gap:5px;">
            <input type="text" class="win-input" style="height:36px; font-size:13px;" placeholder="Cerca Ragione Sociale..." @bind="testoRicerca" @bind:event="oninput" @onkeyup="CercaEnter" />
            <button class="win-btn" style="min-width:40px;" @onclick="EseguiRicerca">🔍</button>
        </div>

        <div style="display:flex; gap:5px;">
            <button class="win-btn" @onclick="Nuovo" style="background:#fff;">➕ Nuovo</button>
            <button class="win-btn" @onclick="Annulla" style="background:#f1f1f1;">✖ Annulla</button>
            <button class="win-btn" @onclick="Salva" style="background:#d4edda; border-color:#28a745;">💾 Salva</button>
            @if(c.IdCliente > 0) {
                <button class="win-btn" @onclick="Elimina" style="background:#f8d7da; border-color:#dc3545; color:#721c24;">🗑️ Elimina</button>
            }
        </div>
    </div>

    <!-- SEZIONE 1: ANAGRAFICA E SCONTI -->
    <div class="win-group">
        <div class="section-title">Dati Generali e Politiche Commerciali</div>
        <table style="width:100%; border-spacing: 4px; table-layout: fixed;">
            <tr>
                <td style="width:8%" class="win-label">Rag. Soc.:</td>
                <td style="width:30%"><input type="text" class="win-input fw-bold" @bind="c.RagSociale" /></td>
                <td style="width:8%" class="win-label">Referente:</td>
                <td style="width:20%"><input type="text" class="win-input" @bind="c.Referente" /></td>
                <td style="width:8%" class="win-label">P.IVA:</td>
                <td style="width:12%"><input type="text" class="win-input" @bind="c.PIva" /></td>
                <td style="width:8%" class="win-label text-primary">Sc. Prof %:</td>
                <td><input type="number" step="0.01" class="win-input text-end fw-bold" @bind="c.ScontoProfili" /></td>
            </tr>
            <tr>
                <td class="win-label">Indirizzo:</td>
                <td><input type="text" class="win-input" @bind="c.Ind_legale" /></td>
                <td class="win-label">Città:</td>
                <td><input type="text" class="win-input" @bind="c.Citta_Legale" /></td>
                <td class="win-label">CAP / Prov:</td>
                <td>
                    <div class="d-flex gap-1">
                        <input type="text" class="win-input" style="width:60%" @bind="c.CAP_Legale" />
                        <input type="text" class="win-input" style="width:40%" @bind="c.Prov_Legale" />
                    </div>
                </td>
                <td class="win-label text-primary">Sc. Acc %:</td>
                <td><input type="number" step="0.01" class="win-input text-end fw-bold" @bind="c.ScontoAccessori" /></td>
            </tr>
        </table>
    </div>

    <!-- SEZIONE 2: CONTATTI E LOGISTICA -->
    <div class="win-group">
        <div class="section-title">Recapiti e Logistica</div>
        <table style="width:100%; border-spacing: 4px; table-layout: fixed;">
            <tr>
                <td style="width:8%" class="win-label">Email:</td>
                <td style="width:30%"><input type="text" class="win-input" @bind="c.Email" /></td>
                <td style="width:8%" class="win-label">Tel / Fax:</td>
                <td style="width:20%">
                    <div class="d-flex gap-1">
                        <input type="text" class="win-input" placeholder="Tel" @bind="c.Telefono" />
                        <input type="text" class="win-input" placeholder="Fax" @bind="c.Fax" />
                    </div>
                </td>
                <td style="width:8%" class="win-label">Cellulari:</td>
                <td style="width:26%">
                    <div class="d-flex gap-1">
                        <input type="text" class="win-input" placeholder="Cell 1" @bind="c.Cel1" />
                        <input type="text" class="win-input" placeholder="Cell 2" @bind="c.Cel2" />
                    </div>
                </td>
            </tr>
            <tr>
                <td class="win-label">Annotazioni:</td>
                <td colspan="3"><input type="text" class="win-input" @bind="c.Annotazioni" /></td>
                <td class="win-label">Opzioni:</td>
                <td>
                    <label class="me-2"><input type="checkbox" @bind="c.Carrello" /> Carrello</label>
                    <label><input type="checkbox" @bind="c.ScaricoAgevole" /> Scarico Agevole</label>
                </td>
            </tr>
        </table>
    </div>

    <!-- SEZIONE 3: DATI BANCARI -->
    <div class="win-group">
        <div class="section-title">Dati Bancari e Pagamenti</div>
        <table style="width:100%; border-spacing: 4px; table-layout: fixed;">
            <tr>
                <td style="width:8%" class="win-label">Banca:</td>
                <td style="width:25%"><input type="text" class="win-input" @bind="c.Banca" /></td>
                <td style="width:8%" class="win-label">Agenzia:</td>
                <td style="width:15%"><input type="text" class="win-input" @bind="c.Agenzia" /></td>
                <td style="width:8%" class="win-label">IBAN:</td>
                <td><input type="text" class="win-input" @bind="c.IBAN" /></td>
            </tr>
            <tr>
                <td class="win-label">Pag. Prop:</td>
                <td><input type="text" class="win-input" @bind="c.PagProposto" /></td>
                <td class="win-label">Pag. Acc:</td>
                <td><input type="text" class="win-input" @bind="c.PagAccettato" /></td>
                <td class="win-label">SDI / CF:</td>
                <td>
                    <div class="d-flex gap-1">
                        <input type="text" class="win-input" placeholder="Cod. SDI" @bind="c.SDI" />
                        <input type="text" class="win-input" placeholder="Cod. Fiscale" @bind="c.CodFiscale" />
                    </div>
                </td>
            </tr>
        </table>
    </div>

    @if (mostraMessaggio) { <div class="toast-msg">@testoNotifica</div> }
</div>

@code {
    private Cliente c = new Cliente();
    private List<int> listaIdClienti = new();
    private int indiceCorrente = -1;
    private string testoRicerca = "";
    private string testoNotifica = "";
    private bool mostraMessaggio = false;
    private string conn = @"Server=.\SQLEXPRESS;Database=GestAgenti;Trusted_Connection=True;TrustServerCertificate=True;";

    [Parameter]
    [SupplyParameterFromQuery(Name = "idCliente")]
    public int? IdClienteQuery { get; set; }

    protected override async Task OnInitializedAsync() {
        await RinfrescaListaID();
        if (listaIdClienti.Any()) {
            indiceCorrente = 0;
            await CaricaCliente(listaIdClienti[indiceCorrente]);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IdClienteQuery.HasValue)
        {
            await CercaESelezionaClientePerId(IdClienteQuery.Value);
        }
    }

    private async Task RinfrescaListaID() {
        using var db = new SqlConnection(conn);
        listaIdClienti = (await db.QueryAsync<int>("SELECT IdCliente FROM Clienti ORDER BY RagSociale")).ToList();
    }

    private async Task CaricaCliente(int id) {
        using var db = new SqlConnection(conn);
        c = await db.QueryFirstOrDefaultAsync<Cliente>("SELECT * FROM Clienti WHERE IdCliente = @id", new { id });
    }

    private async Task Notifica(string msg) {
        testoNotifica = msg; mostraMessaggio = true; StateHasChanged();
        await Task.Delay(3000); mostraMessaggio = false; StateHasChanged();
    }

    private async Task Salva() {
        if (string.IsNullOrWhiteSpace(c.RagSociale)) { await Notifica("⚠️ Ragione Sociale obbligatoria!"); return; }
        using var db = new SqlConnection(conn);
        try {
            if (c.IdCliente == 0) {
                string sql = @"INSERT INTO Clienti (RagSociale, Referente, Ind_legale, Citta_Legale, CAP_Legale, Prov_Legale, Telefono, Fax, Email, Cel1, Cel2, PIva, CodFiscale, SDI, Banca, Agenzia, IBAN, PagProposto, PagAccettato, Annotazioni, ScontoProfili, ScontoAccessori, Carrello, ScaricoAgevole) 
                               OUTPUT INSERTED.IdCliente 
                               VALUES (@RagSociale, @Referente, @Ind_legale, @Citta_Legale, @CAP_Legale, @Prov_Legale, @Telefono, @Fax, @Email, @Cel1, @Cel2, @PIva, @CodFiscale, @SDI, @Banca, @Agenzia, @IBAN, @PagProposto, @PagAccettato, @Annotazioni, @ScontoProfili, @ScontoAccessori, @Carrello, @ScaricoAgevole)";
                c.IdCliente = await db.QuerySingleAsync<int>(sql, c);
                await RinfrescaListaID();
                indiceCorrente = listaIdClienti.IndexOf(c.IdCliente);
            } else {
                string sql = @"UPDATE Clienti SET RagSociale=@RagSociale, Referente=@Referente, Ind_legale=@Ind_legale, Citta_Legale=@Citta_Legale, CAP_Legale=@CAP_Legale, Prov_Legale=@Prov_Legale, Telefono=@Telefono, Fax=@Fax, Email=@Email, Cel1=@Cel1, Cel2=@Cel2, PIva=@PIva, CodFiscale=@CodFiscale, SDI=@SDI, Banca=@Banca, Agenzia=@Agenzia, IBAN=@IBAN, PagProposto=@PagProposto, PagAccettato=@PagAccettato, Annotazioni=@Annotazioni, ScontoProfili=@ScontoProfili, ScontoAccessori=@ScontoAccessori, Carrello=@Carrello, ScaricoAgevole=@ScaricoAgevole WHERE IdCliente=@IdCliente";
                await db.ExecuteAsync(sql, c);
            }
            await Notifica("✅ Cliente salvato correttamente!");
        } catch (Exception ex) { await Notifica("❌ Errore: " + ex.Message); }
    }

    private async Task Elimina() {
        if (!await JS.InvokeAsync<bool>("confirm", "Eliminare definitivamente questo cliente?")) return;
        using var db = new SqlConnection(conn);
        await db.ExecuteAsync("DELETE FROM Clienti WHERE IdCliente=@id", new { id = c.IdCliente });
        await RinfrescaListaID();
        if (listaIdClienti.Any()) { indiceCorrente = 0; await CaricaCliente(listaIdClienti[0]); } else Nuovo();
        await Notifica("🗑️ Cliente rimosso.");
    }

    private async Task Nuovo() { 
        if (!await JS.InvokeAsync<bool>("confirm", "Creare un nuovo cliente e perdere le modifiche non salvate?")) return;
        c = new Cliente(); indiceCorrente = -1; }
    private async Task Annulla() {
        if (!await JS.InvokeAsync<bool>("confirm", "Annullare le modifiche non salvate?")) return;
        if (c.IdCliente == 0) { Nuovo(); return; }
        await CaricaCliente(c.IdCliente);
    }
    private async Task Prev() { if (indiceCorrente > 0) { indiceCorrente--; await CaricaCliente(listaIdClienti[indiceCorrente]); } }
    private async Task Next() { if (indiceCorrente < listaIdClienti.Count - 1) { indiceCorrente++; await CaricaCliente(listaIdClienti[indiceCorrente]); } }

    private async Task EseguiRicerca() {
        if (string.IsNullOrWhiteSpace(testoRicerca)) return;
        using var db = new SqlConnection(conn);
        var trovato = await db.QueryFirstOrDefaultAsync<int?>("SELECT IdCliente FROM Clienti WHERE RagSociale LIKE @t", new { t = "%" + testoRicerca + "%" });
        if (trovato.HasValue) {
            indiceCorrente = listaIdClienti.IndexOf(trovato.Value);
            await CaricaCliente(trovato.Value);
        } else { await Notifica("🔍 Nessun cliente trovato."); }
    }

    private void CercaEnter(KeyboardEventArgs e) { if (e.Key == "Enter") EseguiRicerca(); }

    private async Task CercaESelezionaClientePerId(int id)
    {
        try
        {
            // Se hai un servizio esistente per recuperare il cliente, usalo qui.
            // Esempio generico: var cliente = await ClienteService.GetByIdAsync(id);
            // Qui invece mostriamo solo un log e navigazione/zoom nella UI.
            Console.WriteLine($"Richiesta apertura cliente con Id = {id}");

            // Se la pagina mostra una lista, filtra/ricerca per id e seleziona il record.
            // Esempio fittizio:
            // searchText = id.ToString();
            // await DoSearch();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Errore selezione cliente: " + ex.Message);
        }
    }
}
