        color: white !important;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        margin: 0;
    }

    /* 3. TASTI HOME/AGGIORNA: Stile Dashboard ma con contrasto elevato */
        /* AGGIORNAMENTO PER PULSANTI ALTI IN AGENDA */
