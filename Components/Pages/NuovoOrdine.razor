        var message = new MimeMessage();
        message.From.Add(new MailboxAddress("ALQ Genova", "ugupio@gmail.com"));
        message.To.Add(new MailboxAddress("Ufficio Ordini" , "ugupio@gmail.com"));
        message.Subject = $"Ordine n. {ordine.IDOrdine}";

