    private async Task SalvaTutto() {
    if (ordine.IDCliente == 0) { await Notifica("⚠️ Seleziona un cliente!"); return; }
    using var db = new SqlConnection(conn);
    await db.OpenAsync();
    using var tx = db.BeginTransaction();
    try {
        string sqlO = (ordine.IDOrdine == 0) 
            ? "INSERT INTO Ordini (IDCliente, DataOrdine, NumeroDocumento, RiferimentoCliente, StatoOrdine, TotaleImponibile, DataConsegnaPrevista, DataConsegnaEffettiva, NoteOrdine, ConcordatoCon) OUTPUT INSERTED.IDOrdine VALUES (@IDCliente, @DataOrdine, @NumeroDocumento, @RiferimentoCliente, @StatoOrdine, @TotaleImponibile, @DataConsegnaPrevista, @DataConsegnaEffettiva, @NoteOrdine, @ConcordatoCon)"
            : "UPDATE Ordini SET IDCliente=@IDCliente, DataOrdine=@DataOrdine, NumeroDocumento=@NumeroDocumento, RiferimentoCliente=@RiferimentoCliente, StatoOrdine=@StatoOrdine, TotaleImponibile=@TotaleImponibile, DataConsegnaPrevista=@DataConsegnaPrevista, DataConsegnaEffettiva=@DataConsegnaEffettiva, ConcordatoCon=@ConcordatoCon, NoteOrdine=@NoteOrdine WHERE IDOrdine=@IDOrdine";
        
        if (ordine.IDOrdine == 0) {
            ordine.IDOrdine = await db.QuerySingleAsync<int>(sqlO, ordine, tx);
            listaIdOrdini.Insert(0, ordine.IDOrdine);
        }
        else await db.ExecuteAsync(sqlO, ordine, tx);
        
        await db.ExecuteAsync("DELETE FROM Dettaglio_Ordini WHERE IDOrdine=@ID", new { ID = ordine.IDOrdine }, tx);
        
        foreach (var r in ordine.Righe) {
            r.IDOrdine = ordine.IDOrdine;
            // AGGIORNATO: Inserito UmRiga nella query di inserimento dettaglio
            string sqlR = @"INSERT INTO Dettaglio_Ordini 
                            (IDOrdine, CodiceProdotto, Descrizione, Quantita, UmRiga, PrezzoUnitario, ScontoRiga, ColoreInt, ColoreEst, IsAccessorio, FinituraAccessorio, LunghezzaVerga, PesoAlMetro) 
                            VALUES 
                            (@IDOrdine, @CodiceProdotto, @Descrizione, @Quantita, @UmRiga, @PrezzoUnitario, @ScontoRiga, @ColoreInt, @ColoreEst, @IsAccessorio, @FinituraAccessorio, @LunghezzaVerga, @PesoAlMetro)";
            
            await db.ExecuteAsync(sqlR, r, tx);
        }
        
        tx.Commit();
        
        // Reset dello snapshot per evitare l'avviso di modifiche non salvate dopo il salvataggio corretto
        snapshotOrdineOriginale = System.Text.Json.JsonSerializer.Serialize(ordine);
        
        await Notifica("✅ Salvataggio completato!");
    } catch (Exception ex) { 
        tx.Rollback(); 
        await Notifica("❌ Errore: " + ex.Message); 
    }
}


    private async Task EliminaOrdine() {
        bool conferma = await JS.InvokeAsync<bool>("confirm", "Sei sicuro di voler eliminare questo ordine?");
        if (!conferma) return;
        using var db = new SqlConnection(conn);
        await db.OpenAsync();
        using var tx = db.BeginTransaction();
        try {
            await db.ExecuteAsync("DELETE FROM Dettaglio_Ordini WHERE IDOrdine=@id", new { id = ordine.IDOrdine }, tx);
            await db.ExecuteAsync("DELETE FROM Ordini WHERE IDOrdine=@id", new { id = ordine.IDOrdine }, tx);
            tx.Commit();
            await Notifica("🗑️ Ordine eliminato.");
            listaIdOrdini.Remove(ordine.IDOrdine);
            if (listaIdOrdini.Any()) await CaricaOrdine(listaIdOrdini[0]); else IniziaNuovo();
        } catch (Exception ex) { tx.Rollback(); await Notifica("❌ Errore: " + ex.Message); }
    }

