private void AggiornaConteggi(DettaglioOrdine r)
{
    if (r == null) return;

    // 1. Calcoliamo la base (Prezzo Lordo)
    decimal prezzoLordo;
    if (!r.IsAccessorio) {
        // Peso (Qta * L * P) * Prezzo al Kg
        prezzoLordo = r.Quantita * r.LunghezzaVerga * r.PesoAlMetro * r.PrezzoUnitario;
    } else {
        // Quantità * Prezzo Unitario
        prezzoLordo = r.Quantita * r.PrezzoUnitario;
    }

    // 2. Applichiamo lo sconto (se ScontoRiga è una percentuale, es: 10 per 10%)
    decimal fattoreSconto = (100 - r.ScontoRiga) / 100;
    r.PrezzoTotaleRiga = Math.Round(prezzoLordo * fattoreSconto, 2);

    // 3. Ricalcola il totale ordine
    ordine.TotaleImponibile = ordine.Righe.Sum(x => x.PrezzoTotaleRiga);
    
    StateHasChanged();
}


    
    
    private async Task Annulla()
{
    var snapshotAttuale = JsonSerializer.Serialize(ordine);

    if (snapshotAttuale != snapshotOrdineOriginale)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Ci sono modifiche non salvate. Ripristinare i dati originali?")) 
            return;
    }

    // --- PULIZIA TASK ---
    // Svuotiamo la lista così il box giallo sparisce istantaneamente
    taskPendenti = new(); 

    if (ordine.IDOrdine == 0) 
    { 
        if (listaIdOrdini != null && listaIdOrdini.Any()) 
        {
            indiceCorrente = 0; 
            await CaricaOrdine(listaIdOrdini[indiceCorrente]);
            
            // Dopo aver caricato l'ordine precedente, ricarichiamo i task di quel cliente
            await CaricaTaskDelCliente(); 
        }
        else 
        {
            IniziaNuovo(); 
        }
    }
    else 
    {
        // Se ripristiniamo un ordine esistente, ricarichiamo i suoi task
        await CaricaOrdine(ordine.IDOrdine);
        await CaricaTaskDelCliente();
    }
    
    StateHasChanged();
}

private void CalcolaTotaleOrdine()
{
    // Ricalcola il totale di ogni riga e poi il totale generale
    foreach (var r in ordine.Righe)
    {
        // Esempio: Quantità * Prezzo (meno eventuale sconto)
        r.PrezzoTotaleRiga = r.Quantita * r.PrezzoUnitario; 
    }
    
    // Somma tutti i totali riga nel totale ordine
    ordine.TotaleImponibile = ordine.Righe.Sum(x => x.PrezzoTotaleRiga);
    
    // Notifica a Blazor che i dati sono cambiati e deve ridisegnare la UI
    StateHasChanged();
}



    private async Task Prev() { if (indiceCorrente < listaIdOrdini.Count - 1) { indiceCorrente++; await CaricaOrdine(listaIdOrdini[indiceCorrente]); } }
    private async Task Next() { if (indiceCorrente > 0) { indiceCorrente--; await CaricaOrdine(listaIdOrdini[indiceCorrente]); } }


