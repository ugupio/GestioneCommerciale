            <div><label class="win-label">Rif. Documento</label><input type="text" class="win-input" @bind="ordine.NumeroDocumento" /></div>
            <div class="row">
            <div class="col-md-4">
                <label class="win-label">Riferimento Cliente:</label>
                <input type="text" class="win-input" @bind="ordine.RiferimentoCliente" placeholder="Es. PO-2024-001" />
            </div>
    </div>
            <div>
