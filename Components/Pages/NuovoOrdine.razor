private async Task OnClienteChanged(ChangeEventArgs e)
{
    // Recuperiamo l'ID selezionato dalla select
    if (int.TryParse(e.Value?.ToString(), out int idSelezionato))
    {
        ordine.IDCliente = idSelezionato;
        
        // Se è stato scelto un cliente (ID > 0), carichiamo i suoi task
        if (idSelezionato > 0)
        {
            try {
                using var db = new SqlConnection(conn);
                string sql = "SELECT * FROM Attivita WHERE IDClienteAttivita = @id AND Completata = 0";
                var res = await db.QueryAsync<Attivita>(sql, new { id = idSelezionato });
                taskPendenti = res.ToList();
                // NOTIFICA DI TEST: Se vedi questo messaggio, la query funziona
                if (taskPendenti.Any()) 
                   await Notifica($"✅ Trovati {taskPendenti.Count} task per ID {idSelezionato}");
                else 
                   await Notifica($"ℹ️ Nessun task trovato per ID {idSelezionato}");

                StateHasChanged(); // Forziamo il refresh per mostrare i task appena caricati
            } catch (Exception ex) {
                await Notifica("❌ Errore DB: " + ex.Message);
                taskPendenti = new(); 
            }
        }
        else {
            taskPendenti = new();
        }
    }
}


