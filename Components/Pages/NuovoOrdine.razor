@page "/nuovo-ordine/{id:int}"
@page "/nuovo-ordine"
@rendermode InteractiveServer
@using Microsoft.Data.SqlClient
@using Dapper
@using GestioneCommerciale.Models
@using System.Globalization
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Text.Json
@using QuestPDF.Fluent
@using MailKit.Net.Smtp
@using MimeKit


<style>
    .win-form { background-color: #f0f0f0; font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 11px; border: 1px solid #999; padding: 5px; min-width: 1200px; color: #333; position: relative; min-height: 98vh; }
    .win-header { background: #005a9e; color: white; padding: 3px 8px; font-weight: bold; margin: -5px -5px 5px -5px; font-size: 12px; }
    .win-group { border: 1px solid #c0c0c0; background: #fff; padding: 8px; margin-bottom: 5px; }
    .win-label { font-weight: 500; color: #333; font-size: 10px; display: block; margin-bottom: 2px; }
    .win-input { border: 1px solid #ccc; padding: 1px 4px; height: 21px; width: 100%; font-size: 11px; }
    .win-input:focus { background: #faffbd; outline: 1px solid #0078d7; }
    .toolbar-container { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 5px; background: #fdfdfd; border: 1px solid #c0c0c0; margin-bottom: 5px; }
    .win-grid { width: 100%; border-collapse: collapse; background: white; font-size: 10.5px; }
    .win-grid th { background: #f0f0f0; border: 1px solid #ccc; padding: 4px; text-align: left; position: sticky; top: 0; z-index: 10; }
    .win-grid td { border: 1px solid #eee; padding: 2px 4px; }
    .section-title { font-weight: bold; color: #005a9e; border-bottom: 1px solid #ddd; margin-bottom: 8px; font-size: 10px; text-transform: uppercase; }
    .toast-msg { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 12px 30px; border-radius: 3px; z-index: 9999; box-shadow: 0 5px 15px rgba(0,0,0,0.4); border-left: 5px solid #28a745; font-size: 13px; }
    .input-grid { border: none; background: transparent; width: 100%; text-align: inherit; font-family: inherit; font-size: inherit; }
    .input-grid:focus { background: #fff3cd; outline: 1px solid #ffa500; }
    /* Stile per i mini-input dei colori nella griglia */
    .input-grid-mini {
        border: none;
        background: transparent;
        padding: 0 2px;
        font-size: 0.75rem;
        outline: none;
        border-bottom: 1px dashed transparent;
        transition: all 0.2s;
    }

    .input-grid-mini:hover, .input-grid-mini:focus {
        border-bottom: 1px dashed #ccc;
        background: rgba(255, 255, 255, 0.5);
    }
    
    /* Opzionale: per dare un po' di respiro alla riga della descrizione */
    .input-grid.fw-bold {
        margin-bottom: 0px;
    }

    /* Sfondo oscurato */
.win-modal-backdrop {
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    background: rgba(0, 0, 0, 0.4);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* Finestra Popup */
.win-popup {
    width: 450px;
    background: #f0f0f0;
    border: 1px solid #666;
    box-shadow: 5px 5px 15px rgba(0,0,0,0.3);
}

.popup-body {
    padding: 15px;
    background: #fff;
    margin: 5px;
    border: 1px solid #ccc;
}

/* --- NUOVO STILE PULSANTI --- */
.btn-comando-ordine {
    height: 90px !important;           /* Altezza "Dashboard Style" */
    min-width: 100px !important;        /* Larghezza minima per farli quadrati */
    display: inline-flex !important;
    flex-direction: column !important;  /* Icona sopra, testo sotto */
    align-items: center !important;
    justify-content: center !important;
    gap: 5px !important;
    padding: 10px !important;
    background: #ffffff !important;
    color: #1e3c72 !important;
    font-weight: bold !important;
    border: 2px solid #ffffff !important;
    border-radius: 12px !important;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;
    transition: all 0.2s ease-in-out !important;
    cursor: pointer !important;
    text-transform: uppercase;
    font-size: 10px;                   /* Testo compatto */
    user-select: none !important;
}


/* Effetto Neon (lo stesso) */
.btn-comando-ordine:hover {
    background: #00d2ff !important;
    color: white !important;
    border-color: #00d2ff !important;
    transform: scale(1.05) !important;
    box-shadow: 0 0 20px rgba(0, 210, 255, 0.6) !important;
}

/* Colori iniziali tasti specifici */
.btn-start-verde { background: #d4edda !important; border-color: #28a745 !important; }
.btn-start-rosso { background: #f8d7da !important; border-color: #dc3545 !important; color: #721c24 !important; }
.btn-start-azzurro { background: #e3f2fd !important; border-color: #2196f3 !important; }
.btn-start-nav { background: #f8f9fa !important; border-color: #dee2e6 !important; }

/* Dimensione Icona (Emoji) */
.btn-comando-ordine span:first-child {
    font-size: 2rem !important; 
    pointer-events: none !important;
}

/* Variante grigio chiaro per tasto Annulla */
.btn-start-nav { 
    background: #f8f9fa !important; 
    border-color: #dee2e6 !important; 
}


</style>

<div class="win-form">
    <div class="win-header">Gestione Commerciale Alluminio - Console Ordini v2.3 by Riccardo Gucci soft.</div>

    <!-- TOOLBAR -->
    <div class="toolbar-container">
        <!-- BARRA NAVIGAZIONE -->
<div style="display:flex; gap:10px; margin-bottom: 15px;">
    <button class="btn-comando-ordine btn-start-nav" @onclick='() => Nav.NavigateTo("/")'>
        <span>🏠</span> HOME
    </button>
    <button class="btn-comando-ordine btn-start-nav" @onclick="() => VaiA(Prev)">
        <span>◀</span> PREC.
    </button>
    <button class="btn-comando-ordine btn-start-nav" @onclick="() => VaiA(Next)">
         <span>▶</span><span>SUCC.</span>
    </button>
</div>


        <div style="display:flex; gap:20px; align-items:center;">
            <div style="text-align:right;">
                <span style="color: #666; font-size: 9px; display: block;">PESO TOTALE:</span>
                <span style="font-size: 14px; font-weight: bold; color: #005a9e;">@PesoTotale.ToString("N2") Kg</span>
            </div>
            <div style="background: #eef5fb; border: 1px solid #b8d9f5; padding: 4px 15px; min-width: 200px; text-align:right;">
                <span style="color: #005a9e; font-size: 9px; font-weight: bold; display: block;">TOTALE IMPONIBILE:</span>
                <span style="font-size: 18px; font-weight: bold; color: #28a745;">@ordine.TotaleImponibile.ToString("C2")</span>
            </div>
        </div>

        <div style="display:flex; gap:10px; flex-wrap: wrap;">
    <button class="btn-comando-ordine" @onclick="() => VaiA(IniziaNuovo)">
        <span>➕</span> NUOVO
    </button>

    <button class="btn-comando-ordine btn-start-nav" @onclick="Annulla">
    <span>✖</span>
    <span>ANNULLA</span>
</button>

    <button class="btn-comando-ordine btn-start-verde" @onclick="SalvaTutto">
        <span>💾</span> SALVA
    </button>

    @if (ordine.IDOrdine > 0) {
        <button class="btn-comando-ordine btn-start-rosso" @onclick="EliminaOrdine">
            <span>🗑️</span> ELIMINA
        </button>
    }

    <button class="btn-comando-ordine" @onclick="GeneraIlMioPdf">
        <span>🖨️</span> PDF
    </button>

    <button class="btn-comando-ordine btn-start-azzurro" @onclick="InviaOrdineViaEmail">
        <span>📧</span> EMAIL
    </button>
</div>

    </div>

    <!-- TESTATA -->
    <div class="win-group">
        <!-- RIGA 1: Dati Base -->
        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr; gap: 8px; margin-bottom: 10px;">
            <div>
                <label class="win-label">Cliente</label>
                <select class="win-input" @onchange="OnClienteChanged">
                    <option value="0">-- Seleziona Cliente --</option>
                    @foreach (var c in listaClienti) { 
                        <option value="@c.IdCliente" selected="@(ordine.IDCliente == c.IdCliente)">@c.RagSociale</option> 
                    }
                </select>
            </div>
            
            <div><label class="win-label">Data Ordine</label><input type="date" class="win-input" @bind="ordine.DataOrdine" /></div>
            <div><label class="win-label">Rif. Documento</label><input type="text" class="win-input" @bind="ordine.NumeroDocumento" /></div>
            <div><label class="win-label">Rif. Cliente</label><input type="text" class="win-input" @bind="ordine.RiferimentoCliente" /></div>
            <div>
                <label class="win-label">Stato</label>
                <select class="win-input" @bind="ordine.StatoOrdine">
                    <option value="Preventivo">Preventivo</option>
                    <option value="Ordine">Ordine</option>
                    <option value="Bozza">Bozza</option>
                    <option value="In Lavorazione">In Lavorazione</option>
                    <option value="Completato">Completato</option>
                </select>
            </div>
        </div>

        @if (taskPendenti != null && taskPendenti.Any())
        {
            <div style="background: #fff3cd; border: 1px solid #ffeeba; padding: 4px; margin-bottom: 10px; font-size: 11px; color: #856404;">
                <strong>⚠️ PROMEMORIA:</strong> @string.Join(" • ", taskPendenti.Select(t => t.Descrizione))
            </div>
        }

        <!-- RIGA 2: Allineamento Orizzontale Totale -->
<div style="display: flex; gap: 8px; align-items: flex-end; margin-top: 5px;">
    
    <!-- Concordato con -->
    <div style="flex: 1.5;">
        <label class="win-label">Concordate con:</label>
        <input class="win-input" style="width:100%" @bind="ordine.ConcordatoCon" placeholder="Nome..." />
    </div>

    <!-- Note Ordine (Il più largo) -->
    <div style="flex: 4;">
        <label class="win-label">Note Ordine :</label>
        <input class="win-input" style="width:100%" @bind="ordine.NoteOrdine" placeholder="Note del cliente..." />
    </div>

    <!-- Consegna Prevista -->
    <div style="flex: 1.2;">
        <label class="win-label">Cons. Prevista</label>
        <input type="date" class="win-input" style="width:100%" @bind="ordine.DataConsegnaPrevista" />
    </div>

    <!-- Consegna Effettiva -->
    <div style="flex: 1.2;">
        <label class="win-label">Cons. Effettiva</label>
        <div style="display: flex; gap: 2px;">
            <input type="date" class="win-input" style="width:100%" @bind="ordine.DataConsegnaEffettiva" />
            <button class="win-btn" style="min-width: 20px; height: 21px; padding: 0; color: #dc3545;" 
                    @onclick="() => ordine.DataConsegnaEffettiva = null" title="Cancella data">✖</button>
        </div>
    </div>
</div>
</div>

    <div style="display: flex; gap: 5px; margin-bottom: 5px;">
        <!-- SX: PROFILI -->
        <div class="win-group" style="flex: 1.6; border-left: 5px solid #005a9e; background: #f9fcff;">
            <div class="section-title">📦 INSERIMENTO PROFILI</div>
            <div style="display: grid; grid-template-columns: 100px 1fr 1fr 1fr; gap: 4px; margin-bottom:4px;">
        <div style="display:flex; gap:2px;">
            <input class="win-input" placeholder="Codice" @bind="rigaP.CodiceProdotto" @oninput="OnCodiceProfiloInput" style="font-weight:bold; background:#fffde7;" />
            @if (mostraTastoNuovoProfilo)
            {
                <button class="win-btn-cell" @onclick="ApriPopupProdotto" style="background:#28a745; color:white; width:22px; height:21px; padding:0;">+</button>
            }
        </div>
        <input class="win-input" placeholder="Descrizione Profilo" @bind="rigaP.Descrizione" />
        <input class="win-input" placeholder="Col. Int" @bind="rigaP.ColoreInt" />
        <input class="win-input" placeholder="Col. Est" @bind="rigaP.ColoreEst" />
    </div>
            <div style="display: flex; gap: 6px; align-items: end;">
                <div style="width: 50px;"><label class="win-label">Q.tà</label><input type="number" class="win-input" @bind="rigaP.Quantita" /></div>
                <div style="width: 135px;">
                    <label class="win-label">Metri/Vrg</label>
                    <div class="d-flex gap-1">
                        <!-- <select class="win-input" style="width:55px;" @onchange="OnLunghezzaChanged"> 
                            <option value="6.5">6.5</option>
                            <option value="6.8">6.8</option>
                            <option value="0">Libera</option>
                        </select> -->
                        <input type="number" step="0.01" class="win-input" @bind="rigaP.LunghezzaVerga" />
                    </div>
                </div>
                <div style="width: 60px;"><label class="win-label">Kg/ml</label><input type="number" step="0.001" class="win-input" @bind="rigaP.PesoAlMetro" /></div>
                <div style="width: 65px;"><label class="win-label">€/Kg</label><input type="number" step="0.01" class="win-input" @bind="rigaP.PrezzoUnitario" /></div>
                <div style="width: 45px;"><label class="win-label">Sc%</label><input type="number" class="win-input" @bind="rigaP.ScontoRiga" /></div>
                <div style="flex-grow: 1;"><button class="win-btn" style="background:#005a9e; color:white; height:21px; width:100%;" @onclick="() => AggiungiRiga(false)">AGGIUNGI</button></div>
            </div>
        </div>

        <!-- DX: ACCESSORI -->
<div class="win-group" style="flex: 1; border-left: 5px solid #28a745; background: #fafffb;">
    <div class="section-title">🛠️ INSERIMENTO ACCESSORI</div>
    
    <!-- RIGA 1: CODICE E DESCRIZIONE -->
    <div style="display: grid; grid-template-columns: 120px 1fr; gap: 4px; margin-bottom:4px;">
        <div style="display:flex; gap:2px;">
            <input class="win-input" placeholder="Cod." 
                   @bind="rigaA.CodiceProdotto" 
                   @oninput="OnCodiceAccessorioInput" 
                   style="font-weight:bold; background:#f0fff0; width: 100%;" />
            
            @if (mostraTastoNuovoAccessorio)
            {
                <button class="win-btn-cell" @onclick="ApriPopupAccessorio" 
                        style="background:#28a745; color:white; width:22px; height:21px; padding:0; flex-shrink:0;">+</button>
            }
        </div>
        <input class="win-input" placeholder="Descrizione" @bind="rigaA.Descrizione" />
    </div>

    <!-- RIGA 2: FINITURA E DATI ECONOMICI -->
    <div style="display: flex; gap: 6px; align-items: end;">
        <div style="flex: 2;">
            <label class="win-label">Finitura</label>
            <input class="win-input" placeholder="Es. Nero, Argento..." @bind="rigaA.FinituraAccessorio" />
        </div>
        <div style="width: 50px;">
            <label class="win-label">Q.tà</label>
            <input type="number" class="win-input" @bind="rigaA.Quantita" />
        </div>
        <div style="width: 70px;">
            <label class="win-label">€ Cad.</label>
            <input type="number" step="0.01" class="win-input" @bind="rigaA.PrezzoUnitario" />
        </div>
        <div style="width: 50px;">
            <label class="win-label">Sc%</label>
            <input type="number" class="win-input" @bind="rigaA.ScontoRiga" />
        </div>
        <div style="flex-grow: 1;">
            <button class="win-btn" style="background:#28a745; color:white; height:21px; width:100%; font-weight:bold;" 
                    @onclick="() => AggiungiRiga(true)">
                AGGIUNGI
            </button>
        </div>
    </div>
</div>
</div>

    <!-- GRIGLIA -->
    <div class="win-group" style="height: 300px; overflow-y: auto; padding:0;">
        <table class="win-grid">
            <thead>
                <tr>
    <th style="width:40px;">Tipo</th>
    <th style="width:100px;">Codice</th>
    <th>Descrizione</th>
    <th style="width:40px" class="text-center">UM</th>
    <th class="text-end" style="width:60px;">Q.tà</th>
    
    @* --- TITOLO DINAMICO v2.6 (Corretto) --- *@
    <th class="text-end" style="width:110px; line-height: 1.1; font-size: 0.8rem;">
        <span style="color: #005a9e;">⚖️ Peso ml</span><br />
    </th>

    <th class="text-end" style="width:70px;">m/Vrg</th>

    @* --- TITOLO DINAMICO TOTALI --- *@
    <th class="text-end" style="width:110px; line-height: 1.1; font-size: 0.8rem;">
        <span style="color: #005a9e;">Tot. Kg</span><br />
    </th>

    <th class="text-end" style="width:80px;">Prezzo</th>
    <th class="text-end" style="width:50px;">Sc%</th>
    <th class="text-end" style="width:90px;">Totale</th>
    <th style="width:30px;"></th>
</tr>

            </thead>
            <tbody>
    @foreach (var r in ordine.Righe) 
{
    <tr style="@(r.IsAccessorio ? "background:#fafffb;" : "background:#f9fcff;")">
        <!-- 1. TIPO -->
        <td class="text-center">@(r.IsAccessorio ? "🛠️" : "📦")</td>

        <!-- 2. CODICE -->
        <td style="font-weight:bold; color: #005a9e; padding-left: 5px;">@r.CodiceProdotto</td>

        <td>
    <input class="input-grid fw-bold" @bind="r.Descrizione" style="width:100%; border:none; background:transparent;" />
    
    <div style="font-size: 0.8em; color: #757575; display: flex; gap: 12px; margin-top: 2px; align-items: center;">
        
        <!-- Mostra Colori solo se NON è un accessorio (o se preferisci vederli sempre, togli l'if) -->
        @if (!r.IsAccessorio)
        {
            <div style="display: flex; align-items: center;">
                <span style="margin-right: 3px; font-weight: bold;">INT:</span>
                <input @bind="r.ColoreInt" class="input-grid" style="width: 70px; border: none; background: transparent; color: #757575; border-bottom: 1px dotted #ccc;" />
            </div>
            <div style="display: flex; align-items: center;">
                <span style="margin-right: 3px; font-weight: bold;">EST:</span>
                <input @bind="r.ColoreEst" class="input-grid" style="width: 70px; border: none; background: transparent; color: #757575; border-bottom: 1px dotted #ccc;" />
            </div>
        }

        <!-- Mostra FINITURA solo se è un accessorio -->
        @if (r.IsAccessorio)
        {
            <div style="display: flex; align-items: center; color: #555;">
                <span style="margin-right: 3px; font-weight: bold;">🎨 FINITURA:</span>
                <input @bind="r.FinituraAccessorio" class="input-grid" style="width: 150px; border: none; background: transparent; color: #555; border-bottom: 1px dotted #ccc; font-style: italic;" />
            </div>
        }

        <!-- Se c'è la confezione attiva, aggiungiamo un badge anche qui -->
        @if (r.IsConfezione)
        {
            <span style="color: #28a745; font-weight: bold; font-size: 0.9em;">
                📦 CONF. (@r.UmSecondaria)
            </span>
        }
    </div>
</td>

        <!-- 4. UM -->
        <td class="text-center">
            <select class="form-select form-select-sm border-0 bg-light" style="font-size: 0.8rem; width: 65px; padding: 2px;" @bind="r.UmRiga">
                <option value="ML">ML</option>
                <option value="PZ">PZ</option>
                <option value="KG">KG</option>
                <option value="BAR">BR</option>
            </select>
        </td>

        <!-- 5. QUANTITÀ -->
<td class="text-center">
    <div class="d-flex flex-column align-items-center">
        <!-- Input originale con i tuoi bind -->
        <input type="number" 
               class="input-grid text-end" 
               @bind="r.Quantita" 
               @bind:event="oninput" 
               @onchange="@(() => OnQuantitaModificata(r))" />

        @if (r.IsAccessorio)
        {
            <!-- Toggle compatto sotto l'input -->
            <div @onclick="() => InvertiUsoConfezione(r)"
                @onclick:stopPropagation="true"
                 style="cursor:pointer; font-size: 0.65rem; margin-top: 2px; padding: 1px 5px;z-index:999; border-radius: 4px; border: 1px solid @(r.IsConfezione ? "#28a745" : "#ccc"); background-color: @(r.IsConfezione ? "#e8f5e9" : "#f8f9fa"); color: @(r.IsConfezione ? "#1b5e20" : "#6c757d"); min-width: 60px; text-align: center; user-select: none;">
                
                @if (r.IsConfezione)
                {
                    <span title="Multiplo di @r.PezziPerConfezione">📦 <strong>@r.UmSecondaria</strong></span>
                }
                else
                {
                    <span>⚪ PZ</span>
                }
            </div>
        }
    </div>
</td>


        <!-- 5b. PESO/ML (NUOVA COLONNA EDITABILE) -->
        <td>
            @if(!r.IsAccessorio) {
                <input type="number" step="0.001" class="input-grid text-end fw-bold" 
                       style="color: #005a9e;" 
                       @bind="r.PesoAlMetro" 
                       @bind:event="oninput" 
                       @onchange="@(() => AggiornaConteggi(r))" />
            } else {
                <span class="text-muted d-block text-center">-</span>
            }
        </td>

        <!-- 6. m/Vrg -->
        <td>
            @if(!r.IsAccessorio){ 
                <input type="number" step="0.01" class="input-grid text-end" @bind="r.LunghezzaVerga" @bind:event="oninput" @onchange="@(() => AggiornaConteggi(r))" /> 
            }
        </td>
        
        <!-- 7. PESO TOTALE RIGA (Kg) -->
        <td class="text-end" style="background: #fdfdfd; font-family: 'Courier New';">
            @if(!r.IsAccessorio) {
                <span>@((r.Quantita * r.LunghezzaVerga * r.PesoAlMetro).ToString("N2")) Kg</span>
            } else {
                <span class="text-muted">-</span>
            }
        </td>
        
        <!-- 8. PREZZO -->
        <td>
            <input type="number" step="0.01" class="input-grid text-end" @bind="r.PrezzoUnitario" @onblur="@(() => AggiornaConteggi(r))" />
        </td>
        
        <!-- 9. SC% -->
        <td>
            <input type="number" step="0.1" class="input-grid text-end" @bind="r.ScontoRiga" @onblur="@(() => AggiornaConteggi(r))" />
        </td>
        
        <!-- 10. TOTALE RIGA -->
        <td class="text-end fw-bold">@r.PrezzoTotaleRiga.ToString("N2") €</td>
        
        <!-- 11. AZIONE -->
        <td class="text-center">
            <div style="display: flex; justify-content: center; gap: 6px; align-items: center;">
                <button class="win-btn-tablet" style="color: #28a745;" @onclick="() => AggiornaDatiDaArchivio(r)" title="Importa">🔄</button>
                <button class="win-btn-tablet" style="color: #005a9e;" @onclick="() => SalvaDatiInArchivio(r)" title="Esporta">💾</button>
