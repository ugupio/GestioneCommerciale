    private decimal PesoTotale => ordine.Righe.Where(x => !x.IsAccessorio).Sum(x => x.Quantita * x.LunghezzaVerga * x.PesoAlMetro);

    private void OnLunghezzaChanged(ChangeEventArgs e) {
        if (decimal.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out decimal val) && val > 0)
            rigaP.LunghezzaVerga = val;
    }

    private void Ricalcola() {
    foreach (var r in ordine.Righe) {
        // --- LOGICA CONFEZIONI ---
        // Se i pezzi inseriti sono un multiplo esatto dei pezzi per confezione (e > 0)
        if (r.PezziPerConfezione > 0 && r.Quantita >= r.PezziPerConfezione && (r.Quantita % r.PezziPerConfezione == 0)) 
        {
            r.MostraToggleConfezione = true; // Proprietà da usare nell' @if del toggle
        }
        else 
        {
            r.MostraToggleConfezione = false;
            r.IsConfezione = false; // Se diminuisco la q.tà sotto la soglia, torno a pezzi singoli
        }

        // --- LOGICA CALCOLO PREZZI ---
        // Se è una confezione, il calcolo potrebbe differire (es. prezzo a pacco o manteniamo il prezzo unitario?)
        // Per ora manteniamo la tua logica originale:
        decimal lordo = r.IsAccessorio ? (r.Quantita * r.PrezzoUnitario) : (r.Quantita * r.LunghezzaVerga * r.PesoAlMetro * r.PrezzoUnitario);
        r.PrezzoTotaleRiga = lordo * (1 - (r.ScontoRiga / 100));
    }
    ordine.TotaleImponibile = ordine.Righe.Sum(x => x.PrezzoTotaleRiga);
    StateHasChanged(); // Forza Blazor a ridisegnare la UI e mostrare i toggle
}


    private void AggiungiRiga(bool isAcc) {
    var r = isAcc ? rigaA : rigaP;
    if (string.IsNullOrEmpty(r.Descrizione)) return;

    ordine.Righe.Add(new DettaglioOrdine {
    IDProdotto = r.IDProdotto,          // <--- FONDAMENTALE per il legame
    PezziPerConfezione = r.PezziPerConfezione, // <--- FONDAMENTALE per il Toggle
    UmSecondaria = string.IsNullOrEmpty(r.UmSecondaria) ? "CT" : r.UmSecondaria, // <--- PRENDE IL DATO DAL DB
    CodiceProdotto = r.CodiceProdotto,
    Descrizione = r.Descrizione,
    UmRiga = r.UmRiga,
    IsAccessorio = r.IsAccessorio, 
    Quantita = r.Quantita,
    QuantitaOriginalePezzi = r.Quantita, // <--- Inizializza la memoria
    LunghezzaVerga = r.LunghezzaVerga, 
    PesoAlMetro = r.PesoAlMetro, 
    PrezzoUnitario = r.PrezzoUnitario,
    ScontoRiga = r.ScontoRiga, 
    ColoreInt = r.ColoreInt, 
    ColoreEst = r.ColoreEst, 
    FinituraAccessorio = r.FinituraAccessorio,
});


    Ricalcola();

    // Reset dei campi per il prossimo inserimento
    if (isAcc) 
        rigaA = new() { IsAccessorio = true, Quantita = 1 }; 
    else 
        rigaP = new() { IsAccessorio = false, Quantita = 1, LunghezzaVerga = 6.50m };
}



private async Task InvertiUsoConfezione(DettaglioOrdine r)
{
    // 1. Controllo di sicurezza: se i pezzi sono 0 o 1, il calcolo è inutile
    if (r.PezziPerConfezione <= 1) 
    {
        await JS.InvokeVoidAsync("alert", $"Attenzione: Pezzi per confezione è {r.PezziPerConfezione}. Controlla l'anagrafica del prodotto {r.CodiceProdotto}!");
        r.IsConfezione = !r.IsConfezione;
        StateHasChanged();
        return;
    }

    r.IsConfezione = !r.IsConfezione;

    if (r.IsConfezione)
    {
        r.QuantitaOriginalePezzi = r.Quantita; // Salviamo (es. 20)

        // 2. Calcolo arrotondamento
        decimal qDaCalcolare = r.Quantita > 0 ? r.Quantita : 1;
        decimal nConfezioni = Math.Ceiling(qDaCalcolare / (decimal)r.PezziPerConfezione);
        
        // Aggiornamento quantità reale
        r.Quantita = nConfezioni * r.PezziPerConfezione;
        
        await JS.InvokeVoidAsync("console.log", $"Confezione attivata: {nConfezioni} colli. Nuova Q.tà: {r.Quantita}");
    }
    else
    {
        // Ripristino
        r.Quantita = r.QuantitaOriginalePezzi;
    }

    AggiornaConteggi(r); // Questo deve ricalcolare r.PrezzoTotaleRiga
    StateHasChanged(); // Obbligatorio per vedere il cambio nell'input
}








