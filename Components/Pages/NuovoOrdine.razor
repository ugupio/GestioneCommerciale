</div>

@code {
    private Ordine ordine = new() { DataOrdine = DateTime.Now, DataConsegnaPrevista = DateTime.Now.AddDays(7), StatoOrdine = "Preventivo" };
    private DettaglioOrdine rigaP = new() { IsAccessorio = false, Quantita = 1, LunghezzaVerga = 6.50m };
    private DettaglioOrdine rigaA = new() { IsAccessorio = true, Quantita = 1 };
    private List<Cliente> listaClienti = new();
    private List<int> listaIdOrdini = new();
    private int indiceCorrente = -1;
    private string testoNotifica = "";
    private bool mostraMessaggio = false;
    private string conn = @"Server=.\SQLEXPRESS;Database=GestAgenti;Trusted_Connection=True;TrustServerCertificate=True;";
    private string snapshotOriginale = "";
    // Metodo IsDirty che controlla l'intero oggetto ordine (incluse le righe)
    private bool IsDirty() => snapshotOriginale != JsonSerializer.Serialize(ordine);
    private bool mostraTastoNuovoOrdine = false;
    private bool mostraTastoNuovoProfilo = false;
    private bool visualizzaPopupProdotto = false;
    private Prodotti nuovoProdottoListino = new();
    private string snapshotInizialeRiga = "";
    private string snapshotOrdineOriginale = "";
    private bool mostraTastoNuovoAccessorio = false;
    

    @code {
    private async Task GeneraIlMioPdf()
    {
    try 
    {
        // Cerchiamo il cliente corrispondente nell'anagrafica caricata
        var clienteSelezionato = listaClienti.FirstOrDefault(c => c.IdCliente == ordine.IDCliente);
        
        // Se non lo trova (ordine nuovo), creiamo un oggetto temporaneo per non far crashare il PDF
        if (clienteSelezionato == null) 
        {
            clienteSelezionato = new Cliente { RagSociale = "Cliente da definire" };
        }

        // Creiamo il documento
        var documento = new DocumentoOrdine(ordine, clienteSelezionato); 
        byte[] pdfBytes = documento.GeneratePdf();

        // Download
        using var stream = new MemoryStream(pdfBytes);
        using var streamRef = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("downloadFileFromStream", $"Ordine_{ordine.IDOrdine}.pdf", streamRef);
    }
    catch (Exception ex)
    {
        await JS.InvokeVoidAsync("alert", "ERRORE GENERAZIONE: " + ex.Message);
    }
}
}

private void ApriPopupProdotto()
{
    // Prepariamo l'oggetto per il listino usando quello che hai già scritto nella riga
    nuovoProdottoListino = new Prodotti 
    { 
        CodiceProdotto = rigaP.CodiceProdotto, //Prende solo il codice che stavi scrivendo
        Descrizione = "",
        PesoAlMetro = 0m,
        LunghezzaVerga = 6.5m, // Default, l'utente può cambiarlo
        IsAccessorio = false, // Siamo nel blocco profili
        UM = "ML" // Unità di misura predefinita per i profili"
    };
    snapshotInizialeRiga = JsonSerializer.Serialize(nuovoProdottoListino);
    visualizzaPopupProdotto = true;
}

private async Task OnCodiceProfiloInput(ChangeEventArgs e)
{ // <--- APRE IL METODO
    string codice = e.Value?.ToString() ?? "";
    rigaP.CodiceProdotto = codice;

    if (string.IsNullOrWhiteSpace(codice) || codice.Length < 2) 
    { // <--- APRE IF
        mostraTastoNuovoProfilo = false;
        return;
    } // <--- CHIUDE IF

    using (var db = new SqlConnection(conn))
    { // <--- APRE USING
        var p = await db.QueryFirstOrDefaultAsync<Prodotti>(
            "SELECT * FROM Prodotti WHERE CodiceProdotto = @codice", new { codice });

        if (p != null) 
        { // <--- APRE IF
            rigaP.Descrizione = p.Descrizione;
            rigaP.PesoAlMetro = p.PesoAlMetro;
            mostraTastoNuovoProfilo = false;
        } 
        else 
        { // <--- APRE ELSE
            mostraTastoNuovoProfilo = true;
        } // <--- CHIUDE ELSE
    } // <--- CHIUDE USING
} // <--- CHIUDE IL METODO (Questa è quella che probabilmente manca!)


private async Task OnCodiceAccessorioInput(ChangeEventArgs e)
{
    string codice = e.Value?.ToString() ?? "";
    rigaA.CodiceProdotto = codice;

    if (string.IsNullOrWhiteSpace(codice) || codice.Length < 2) {
        mostraTastoNuovoAccessorio = false;
        return;
    }

    using var db = new SqlConnection(conn);
    var p = await db.QueryFirstOrDefaultAsync<Prodotti>(
        "SELECT * FROM Prodotti WHERE CodiceProdotto = @codice", new { codice });

    if (p != null) {
        rigaA.Descrizione = p.Descrizione;
        rigaA.FinituraAccessorio = p.FinituraAccessorio;
        mostraTastoNuovoAccessorio = false;
    } else {
        mostraTastoNuovoAccessorio = true;
    }
}


private void ApriPopupAccessorio()
{
    nuovoProdottoListino = new Prodotti 
    { 
        CodiceProdotto = rigaA.CodiceProdotto, // Mantiene solo il codice che stavi scrivendo
        Descrizione = "",
        FinituraAccessorio = "",
        IsAccessorio = true,
        UM = "PZ",
        PesoAlMetro = 0,
        LunghezzaVerga = 0
    };
    
    snapshotInizialeRiga = JsonSerializer.Serialize(nuovoProdottoListino);
    visualizzaPopupProdotto = true;
}


private async Task InviaOrdineViaEmail()
{
    try
    {
