        // Aggiunta dell'allegato PDF
        bodyBuilder.Attachments.Add($"Ordine_{ordine.IDOrdine}.pdf", pdfBytes);
        message.Body = bodyBuilder.ToMessageBody();

        // 3. Invio tramite SMTP
        using (var client = new SmtpClient())
        {
            // Questo dice al programma di accettare il certificato anche se l'antivirus prova a intercettarlo
    client.ServerCertificateValidationCallback = (s, c, h, e) => true;

    // Usiamo la porta 587 con StartTls (è la più compatibile con i firewall aziendali)
