private async Task OnCodiceProfiloInput(ChangeEventArgs e)
{ 
    string codice = e.Value?.ToString() ?? "";
    rigaP.CodiceProdotto = codice;

    if (string.IsNullOrWhiteSpace(codice) || codice.Length < 2) 
    { 
        mostraTastoNuovoProfilo = false;
        return;
    } 

    using (var db = new SqlConnection(conn))
    {
        //Cerchiamo il prodotto
        var p = await db.QueryFirstOrDefaultAsync<Prodotti>(
            "SELECT * FROM Prodotti WHERE CodiceProdotto = @codice", new { codice });

        if (p != null) 
        { 
            rigaP.Descrizione = p.Descrizione;
            rigaP.PesoAlMetro = p.PesoAlMetro;
            rigaP.UmRiga = p.UmProdotto;
            mostraTastoNuovoProfilo = false;
            // 2. --- RADAR TASK: Controlliamo se ci sono task aperti per questo codice ---
            var task = await db.QueryFirstOrDefaultAsync<Attivita>(
                "SELECT * FROM Attivita WHERE IDProdottoAttivita = @IDProdotto AND Completata = 0", 
                new { IDProdotto = p.IDProdotto }); // Assicurati che IDProdotto sia il nome corretto nella tabella Prodotti

            if (task != null)
            {
                await JS.InvokeVoidAsync("alert", $"⚠️ NOTA TECNICA ARTICOLO {codice}:\n{task.Descrizione}");
            }

        } 
        else 
        { 
            mostraTastoNuovoProfilo = true;
            rigaP.Descrizione = "";
            rigaP.UmRiga = "";
        } 
    } 
} 


