@page "/nuovo-ordine"
@rendermode InteractiveServer
@using Microsoft.Data.SqlClient
@using Dapper
@using GestioneCommerciale.Models
@using System.Globalization
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Text.Json


<style>
    .win-form { background-color: #f0f0f0; font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 11px; border: 1px solid #999; padding: 5px; min-width: 1200px; color: #333; position: relative; min-height: 98vh; }
    .win-header { background: #005a9e; color: white; padding: 3px 8px; font-weight: bold; margin: -5px -5px 5px -5px; font-size: 12px; }
    .win-group { border: 1px solid #c0c0c0; background: #fff; padding: 8px; margin-bottom: 5px; }
    .win-label { font-weight: 500; color: #333; font-size: 10px; display: block; margin-bottom: 2px; }
    .win-input { border: 1px solid #ccc; padding: 1px 4px; height: 21px; width: 100%; font-size: 11px; }
    .win-input:focus { background: #faffbd; outline: 1px solid #0078d7; }
    .toolbar-container { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 5px; background: #fdfdfd; border: 1px solid #c0c0c0; margin-bottom: 5px; }
    .win-btn { background: #e1e1e1; border: 1px solid #adadad; padding: 0 15px; color: black; font-size: 11px; height: 64px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; min-width: 85px; text-decoration:none; }
    .win-btn:hover { background: #e5f1fb; border-color: #0078d7; }
    .win-grid { width: 100%; border-collapse: collapse; background: white; font-size: 10.5px; }
    .win-grid th { background: #f0f0f0; border: 1px solid #ccc; padding: 4px; text-align: left; position: sticky; top: 0; z-index: 10; }
    .win-grid td { border: 1px solid #eee; padding: 2px 4px; }
    .section-title { font-weight: bold; color: #005a9e; border-bottom: 1px solid #ddd; margin-bottom: 8px; font-size: 10px; text-transform: uppercase; }
    .toast-msg { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 12px 30px; border-radius: 3px; z-index: 9999; box-shadow: 0 5px 15px rgba(0,0,0,0.4); border-left: 5px solid #28a745; font-size: 13px; }
    .input-grid { border: none; background: transparent; width: 100%; text-align: inherit; font-family: inherit; font-size: inherit; }
    .input-grid:focus { background: #fff3cd; outline: 1px solid #ffa500; }
    /* Stile per i mini-input dei colori nella griglia */
    .input-grid-mini {
        border: none;
        background: transparent;
        padding: 0 2px;
        font-size: 0.75rem;
        outline: none;
        border-bottom: 1px dashed transparent;
        transition: all 0.2s;
    }

    .input-grid-mini:hover, .input-grid-mini:focus {
        border-bottom: 1px dashed #ccc;
        background: rgba(255, 255, 255, 0.5);
    }
    
    /* Opzionale: per dare un po' di respiro alla riga della descrizione */
    .input-grid.fw-bold {
        margin-bottom: 0px;
    }
</style>

<div class="win-form">
    <div class="win-header">Gestione Commerciale Alluminio - Console Ordini v2.3 by Riccardo Gucci soft.</div>

    <!-- TOOLBAR -->
    <div class="toolbar-container">
        <div style="display:flex; gap:5px;">
            <button class="win-btn" @onclick='() => Nav.NavigateTo("/")'>🏠 Home</button>
            <button class="win-btn" @onclick="Prev">◀ Prec.</button>
            <button class="win-btn" @onclick="Next">Succ. ▶</button>
        </div>

        <div style="display:flex; gap:20px; align-items:center;">
            <div style="text-align:right;">
                <span style="color: #666; font-size: 9px; display: block;">PESO TOTALE:</span>
                <span style="font-size: 14px; font-weight: bold; color: #005a9e;">@PesoTotale.ToString("N2") Kg</span>
            </div>
            <div style="background: #eef5fb; border: 1px solid #b8d9f5; padding: 4px 15px; min-width: 200px; text-align:right;">
                <span style="color: #005a9e; font-size: 9px; font-weight: bold; display: block;">TOTALE IMPONIBILE:</span>
                <span style="font-size: 18px; font-weight: bold; color: #28a745;">@ordine.TotaleImponibile.ToString("C2")</span>
            </div>
        </div>

        <div style="display:flex; gap:5px;">
            <button class="win-btn" @onclick="IniziaNuovo">➕ Nuovo</button>
            <button class="win-btn" @onclick="Annulla" style="background:#f1f1f1;">✖ Annulla</button>
            <button class="win-btn" @onclick="SalvaTutto" style="background:#d4edda; border-color:#28a745;">💾 Salva</button>
            @if (ordine.IDOrdine > 0)
            {
                <button class="win-btn" @onclick="EliminaOrdine" style="background:#f8d7da; border-color:#dc3545; color:#721c24;">🗑️ Elimina</button>
            }
            <button class="win-btn" style="background:#fff;">🖨️ PDF</button>
        </div>
    </div>

    <!-- TESTATA -->
    <div class="win-group">
        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr; gap: 8px;">
            <div style="grid-column: span 2;">
                <label class="win-label">Cliente</label>
                <select class="win-input" @bind="ordine.IDCliente">
                    <option value="0">-- Seleziona Cliente --</option>
                    @foreach (var c in listaClienti) { <option value="@c.IdCliente">@c.RagSociale</option> }
                </select>
            </div>
            <div><label class="win-label">Data Ordine</label><input type="date" class="win-input" @bind="ordine.DataOrdine" /></div>
            <div><label class="win-label">Rif. Documento</label><input type="text" class="win-input" @bind="ordine.NumeroDocumento" /></div>
            <div>
                <label class="win-label">Stato</label>
                <select class="win-input" @bind="ordine.StatoOrdine">
                    <option value="Preventivo">Preventivo</option>
                    <option value="Ordine">Ordine</option>
                    <option value="Bozza">Bozza</option>
                    <option value="In Lavorazione">In Lavorazione</option>
                    <option value="Completato">Completato</option>
                </select>
            </div>
            <div><label class="win-label">Consegna Prevista</label><input type="date" class="win-input" @bind="ordine.DataConsegnaPrevista" /></div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 5fr; gap: 8px; margin-top: 8px;">
            <div>
                <label class="win-label">Cons. Effettiva</label>
                <div style="display: flex; gap: 2px;">
                    <input type="date" class="win-input" @bind="ordine.DataConsegnaEffettiva" />
                    <button class="win-btn" style="min-width: 20px; height: 21px; padding: 0; color: #dc3545;" @onclick="() => ordine.DataConsegnaEffettiva = null">✖</button>
                </div>
            </div>
        </div>
    </div>

    <div style="display: flex; gap: 5px; margin-bottom: 5px;">
        <!-- SX: PROFILI -->
        <div class="win-group" style="flex: 1.6; border-left: 5px solid #005a9e; background: #f9fcff;">
            <div class="section-title">📦 INSERIMENTO PROFILI</div>
            <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 4px; margin-bottom:4px;">
                <input class="win-input" placeholder="Descrizione Profilo" @bind="rigaP.Descrizione" />
                <input class="win-input" placeholder="Col. Int" @bind="rigaP.ColoreInt" />
                <input class="win-input" placeholder="Col. Est" @bind="rigaP.ColoreEst" />
            </div>
            <div style="display: flex; gap: 6px; align-items: end;">
                <div style="width: 50px;"><label class="win-label">Q.tà</label><input type="number" class="win-input" @bind="rigaP.Quantita" /></div>
                <div style="width: 135px;">
                    <label class="win-label">Metri/Vrg</label>
                    <div class="d-flex gap-1">
                        <select class="win-input" style="width:55px;" @onchange="OnLunghezzaChanged">
                            <option value="6.5">6.5</option>
                            <option value="6.8">6.8</option>
                            <option value="0">Libera</option>
                        </select>
                        <input type="number" step="0.01" class="win-input" @bind="rigaP.LunghezzaVerga" />
                    </div>
                </div>
                <div style="width: 60px;"><label class="win-label">Kg/ml</label><input type="number" step="0.001" class="win-input" @bind="rigaP.PesoAlMetro" /></div>
                <div style="width: 65px;"><label class="win-label">€/Kg</label><input type="number" step="0.01" class="win-input" @bind="rigaP.PrezzoUnitario" /></div>
                <div style="width: 45px;"><label class="win-label">Sc%</label><input type="number" class="win-input" @bind="rigaP.ScontoRiga" /></div>
                <div style="flex-grow: 1;"><button class="win-btn" style="background:#005a9e; color:white; height:21px; width:100%;" @onclick="() => AggiungiRiga(false)">AGGIUNGI</button></div>
            </div>
        </div>

        <!-- DX: ACCESSORI -->
        <div class="win-group" style="flex: 1; border-left: 5px solid #28a745; background: #fafffb;">
            <div class="section-title">🛠️ INSERIMENTO ACCESSORI</div>
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 4px; margin-bottom:4px;">
                <input class="win-input" placeholder="Descrizione" @bind="rigaA.Descrizione" />
                <input class="win-input" placeholder="Finitura" @bind="rigaA.FinituraAccessorio" />
            </div>
            <div style="display: flex; gap: 6px; align-items: end;">
                <div style="width: 50px;"><label class="win-label">Q.tà</label><input type="number" class="win-input" @bind="rigaA.Quantita" /></div>
                <div style="width: 70px;"><label class="win-label">€ Cad.</label><input type="number" step="0.01" class="win-input" @bind="rigaA.PrezzoUnitario" /></div>
                <div style="width: 50px;"><label class="win-label">Sc%</label><input type="number" class="win-input" @bind="rigaA.ScontoRiga" /></div>
                <div style="flex-grow: 1;"><button class="win-btn" style="background:#28a745; color:white; height:21px; width:100%;" @onclick="() => AggiungiRiga(true)">AGGIUNGI</button></div>
            </div>
        </div>
    </div>

    <!-- GRIGLIA -->
    <div class="win-group" style="height: 300px; overflow-y: auto; padding:0;">
        <table class="win-grid">
            <thead>
                <tr>
                    <th style="width:40px;">Tipo</th>
                    <th>Descrizione</th>
                    <th class="text-end" style="width:60px;">Q.tà</th>
                    <th class="text-end" style="width:70px;">m/Vrg</th>
                    <th class="text-end" style="width:70px;">Peso</th>
                    <th class="text-end" style="width:80px;">Prezzo</th>
                    <th class="text-end" style="width:50px;">Sc%</th>
                    <th class="text-end" style="width:90px;">Totale</th>
                    <th style="width:30px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in ordine.Righe) {
                    <tr style="@(r.IsAccessorio ? "background:#fafffb;" : "background:#f9fcff;")">
                        <td class="text-center">@(r.IsAccessorio ? "🛠️" : "📦")</td>
                        <td>
    <!-- Input principale Descrizione -->
    <input class="input-grid fw-bold" @bind="r.Descrizione" />

    <div style="font-size: 0.75rem; color: #888; display: flex; gap: 10px; padding: 0 4px; margin-top: -2px;">
        @if (!r.IsAccessorio)
        {
            <!-- Profilo: Titoli fissi, nessun suggerimento negli input -->
            <div style="display: flex; align-items: center; gap: 3px;">
                <span>INT:</span>
                <input class="input-grid-mini" style="width: 70px;" @bind="r.ColoreInt" />
            </div>
            <div style="display: flex; align-items: center; gap: 3px;">
                <span>EST:</span>
                <input class="input-grid-mini" style="width: 70px;" @bind="r.ColoreEst" />
            </div>
        }
        else
        {
            <!-- Accessorio: Titolo fisso, nessun suggerimento -->
            <div style="display: flex; align-items: center; gap: 3px;">
                <span>FIN:</span>
                <input class="input-grid-mini" style="width: 150px;" @bind="r.FinituraAccessorio" />
            </div>
        }
    </div>
</td>

                        <td><input type="number" class="input-grid text-end" @bind="r.Quantita" @oninput="Ricalcola" /></td>
                        <td>@if(!r.IsAccessorio){ <input type="number" step="0.01" class="input-grid text-end" @bind="r.LunghezzaVerga" @oninput="Ricalcola" /> }</td>
                        <td class="text-end">@((!r.IsAccessorio ? (r.Quantita * r.LunghezzaVerga * r.PesoAlMetro) : 0).ToString("N2"))</td>
                        <td><input type="number" step="0.01" class="input-grid text-end" @bind="r.PrezzoUnitario" @oninput="Ricalcola" /></td>
                        <td><input type="number" class="input-grid text-end" @bind="r.ScontoRiga" @oninput="Ricalcola" /></td>
                        <td class="text-end fw-bold">@r.PrezzoTotaleRiga.ToString("N2") €</td>
                        <td class="text-center"><button class="border-0 bg-transparent text-danger" @onclick="() => RimuoviRiga(r)">✖</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (mostraMessaggio) { <div class="toast-msg">@testoNotifica</div> }
</div>

@code {
    private Ordine ordine = new() { DataOrdine = DateTime.Now, DataConsegnaPrevista = DateTime.Now.AddDays(7), StatoOrdine = "Preventivo" };
    private DettaglioOrdine rigaP = new() { IsAccessorio = false, Quantita = 1, LunghezzaVerga = 6.50m };
    private DettaglioOrdine rigaA = new() { IsAccessorio = true, Quantita = 1 };
    private List<Cliente> listaClienti = new();
    private List<int> listaIdOrdini = new();
    private int indiceCorrente = -1;
    private string testoNotifica = "";
    private bool mostraMessaggio = false;
    private string conn = @"Server=.\SQLEXPRESS;Database=GestAgenti;Trusted_Connection=True;TrustServerCertificate=True;";
    private string snapshotOriginale = "";
    // Metodo IsDirty che controlla l'intero oggetto ordine (incluse le righe)
    private bool IsDirty() => snapshotOriginale != JsonSerializer.Serialize(ordine);


    protected override async Task OnInitializedAsync() {
        using var db = new SqlConnection(conn);
        listaClienti = (await db.QueryAsync<Cliente>("SELECT IdCliente, RagSociale FROM Clienti ORDER BY RagSociale")).ToList();
        listaIdOrdini = (await db.QueryAsync<int>("SELECT IDOrdine FROM Ordini ORDER BY IDOrdine DESC")).ToList();
        if (listaIdOrdini.Any()) { indiceCorrente = 0; await CaricaOrdine(listaIdOrdini[0]); }
    }

    private decimal PesoTotale => ordine.Righe.Where(x => !x.IsAccessorio).Sum(x => x.Quantita * x.LunghezzaVerga * x.PesoAlMetro);

    private void OnLunghezzaChanged(ChangeEventArgs e) {
        if (decimal.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out decimal val) && val > 0)
            rigaP.LunghezzaVerga = val;
    }

    private void Ricalcola() {
        foreach (var r in ordine.Righe) {
            decimal lordo = r.IsAccessorio ? (r.Quantita * r.PrezzoUnitario) : (r.Quantita * r.LunghezzaVerga * r.PesoAlMetro * r.PrezzoUnitario);
            r.PrezzoTotaleRiga = lordo * (1 - (r.ScontoRiga / 100));
        }
        ordine.TotaleImponibile = ordine.Righe.Sum(x => x.PrezzoTotaleRiga);
    }

    private void AggiungiRiga(bool isAcc) {
        var r = isAcc ? rigaA : rigaP;
        if (string.IsNullOrEmpty(r.Descrizione)) return;
        ordine.Righe.Add(new DettaglioOrdine {
            Descrizione = r.Descrizione, IsAccessorio = r.IsAccessorio, Quantita = r.Quantita,
            LunghezzaVerga = r.LunghezzaVerga, PesoAlMetro = r.PesoAlMetro, PrezzoUnitario = r.PrezzoUnitario,
            ScontoRiga = r.ScontoRiga, ColoreInt = r.ColoreInt, ColoreEst = r.ColoreEst, FinituraAccessorio = r.FinituraAccessorio
        });
        Ricalcola();
        if (isAcc) rigaA = new() { IsAccessorio = true, Quantita = 1 }; else rigaP = new() { IsAccessorio = false, Quantita = 1, LunghezzaVerga = 6.50m };
    }

    private void RimuoviRiga(DettaglioOrdine r) { ordine.Righe.Remove(r); Ricalcola(); }

    private async Task SalvaTutto() {
        if (ordine.IDCliente == 0) { await Notifica("⚠️ Seleziona un cliente!"); return; }
        using var db = new SqlConnection(conn);
        await db.OpenAsync();
        using var tx = db.BeginTransaction();
        try {
            string sqlO = (ordine.IDOrdine == 0) 
                ? "INSERT INTO Ordini (IDCliente, DataOrdine, NumeroDocumento, StatoOrdine, TotaleImponibile, DataConsegnaPrevista, DataConsegnaEffettiva) OUTPUT INSERTED.IDOrdine VALUES (@IDCliente, @DataOrdine, @NumeroDocumento, @StatoOrdine, @TotaleImponibile, @DataConsegnaPrevista, @DataConsegnaEffettiva)"
                : "UPDATE Ordini SET IDCliente=@IDCliente, DataOrdine=@DataOrdine, NumeroDocumento=@NumeroDocumento, StatoOrdine=@StatoOrdine, TotaleImponibile=@TotaleImponibile, DataConsegnaPrevista=@DataConsegnaPrevista, DataConsegnaEffettiva=@DataConsegnaEffettiva WHERE IDOrdine=@IDOrdine";
            if (ordine.IDOrdine == 0) {
                ordine.IDOrdine = await db.QuerySingleAsync<int>(sqlO, ordine, tx);
                listaIdOrdini.Insert(0, ordine.IDOrdine);
            }
            else await db.ExecuteAsync(sqlO, ordine, tx);
            
            await db.ExecuteAsync("DELETE FROM Dettaglio_Ordini WHERE IDOrdine=@ID", new { ID = ordine.IDOrdine }, tx);
            foreach (var r in ordine.Righe) {
                r.IDOrdine = ordine.IDOrdine;
                string sqlR = "INSERT INTO Dettaglio_Ordini (IDOrdine, Descrizione, Quantita, PrezzoUnitario, ScontoRiga, ColoreInt, ColoreEst, IsAccessorio, FinituraAccessorio, LunghezzaVerga, PesoAlMetro) VALUES (@IDOrdine, @Descrizione, @Quantita, @PrezzoUnitario, @ScontoRiga, @ColoreInt, @ColoreEst, @IsAccessorio, @FinituraAccessorio, @LunghezzaVerga, @PesoAlMetro)";
                await db.ExecuteAsync(sqlR, r, tx);
            }
            tx.Commit();
            await Notifica("✅ Salvataggio completato!");
        } catch (Exception ex) { tx.Rollback(); await Notifica("❌ Errore: " + ex.Message); }
    }

    private async Task EliminaOrdine() {
        bool conferma = await JS.InvokeAsync<bool>("confirm", "Sei sicuro di voler eliminare questo ordine?");
        if (!conferma) return;
        using var db = new SqlConnection(conn);
        await db.OpenAsync();
        using var tx = db.BeginTransaction();
        try {
            await db.ExecuteAsync("DELETE FROM Dettaglio_Ordini WHERE IDOrdine=@id", new { id = ordine.IDOrdine }, tx);
            await db.ExecuteAsync("DELETE FROM Ordini WHERE IDOrdine=@id", new { id = ordine.IDOrdine }, tx);
            tx.Commit();
            await Notifica("🗑️ Ordine eliminato.");
            listaIdOrdini.Remove(ordine.IDOrdine);
            if (listaIdOrdini.Any()) await CaricaOrdine(listaIdOrdini[0]); else IniziaNuovo();
        } catch (Exception ex) { tx.Rollback(); await Notifica("❌ Errore: " + ex.Message); }
    }

    private async Task CaricaOrdine(int id) {
        using var db = new SqlConnection(conn);
        ordine = await db.QueryFirstOrDefaultAsync<Ordine>("SELECT * FROM Ordini WHERE IDOrdine = @id", new { id });
        ordine.Righe = (await db.QueryAsync<DettaglioOrdine>("SELECT * FROM Dettaglio_Ordini WHERE IDOrdine = @id", new { id })).ToList();
        Ricalcola();
    }

    private bool IsPreventivo => string.Equals(ordine.StatoOrdine, "Preventivo", StringComparison.OrdinalIgnoreCase);

    private async Task Notifica(string msg) { testoNotifica = msg; mostraMessaggio = true; StateHasChanged(); await Task.Delay(3000); mostraMessaggio = false; StateHasChanged(); }
    private async Task IniziaNuovo()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Creare un nuovo ordine e perdere le modifiche non salvate?")) return;
        ordine = new Ordine { DataOrdine = DateTime.Now, DataConsegnaPrevista = DateTime.Now.AddDays(7) }; indiceCorrente = -1; Ricalcola();
    }
    private async Task Annulla()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Annullare le modifiche non salvate?")) return;
        if (ordine.IDOrdine == 0) { IniziaNuovo(); return; }
        await CaricaOrdine(ordine.IDOrdine);
    }
    private async Task Prev() { if (indiceCorrente < listaIdOrdini.Count - 1) { indiceCorrente++; await CaricaOrdine(listaIdOrdini[indiceCorrente]); } }
    private async Task Next() { if (indiceCorrente > 0) { indiceCorrente--; await CaricaOrdine(listaIdOrdini[indiceCorrente]); } }
}
