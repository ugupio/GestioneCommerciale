private async Task AggiornaDatiDaArchivio(DettaglioOrdine riga)
{
    using var db = new Microsoft.Data.SqlClient.SqlConnection(conn);
    
    // Peschiamo i dati aggiornati dall'anagrafica
    string sql = "SELECT * FROM Prodotti WHERE CodiceProdotto = @Codice";
    var prodottoAggiornato = await db.QueryFirstOrDefaultAsync<Prodotti>(sql, new { Codice = riga.CodiceProdotto });

    if (prodottoAggiornato != null)
    {
        // Sovrascriviamo solo i dati tecnici che possono cambiare
        riga.PesoAlMetro = prodottoAggiornato.PesoAlMetro;
        riga.LunghezzaVerga = prodottoAggiornato.LunghezzaVerga;
        riga.Descrizione = prodottoAggiornato.Descrizione; // Opzionale
        riga.IsAccessorio = prodottoAggiornato.IsAccessorio;
        riga.UmRiga = prodottoAggiornato.UmProdotto;

        // Ricalcoliamo subito i totali della riga e dell'ordine
        Ricalcola(); 
        
        await JS.InvokeVoidAsync("console.log", $"Dati aggiornati per {riga.CodiceProdotto}");
    }
    else
    {
        await JS.InvokeVoidAsync("alert", "Prodotto non trovato in archivio. Impossibile aggiornare.");
    }
}

    
    
    private async Task Annulla()
{
    var snapshotAttuale = JsonSerializer.Serialize(ordine);

    if (snapshotAttuale != snapshotOrdineOriginale)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "⚠️ Ripristinare i dati originali? Le modifiche andranno perse.")) 
            return;
    }

    taskPendenti = new(); 

    if (ordine.IDOrdine == 0) 
    { 
        if (listaIdOrdini?.Any() == true) 
        {
            indiceCorrente = 0; 
            await CaricaOrdine(listaIdOrdini[indiceCorrente]);
            await CaricaTaskDelCliente(); 
        }
        else 
        {
            IniziaNuovo(); 
        }
    }
    else 
    {
        await CaricaOrdine(ordine.IDOrdine);
        await CaricaTaskDelCliente();
    }
    
    // FORZA LO SNAPSHOT QUI se non lo fai già dentro CaricaOrdine
    snapshotOrdineOriginale = JsonSerializer.Serialize(ordine);
    
    await Notifica("🔄 Dati ripristinati");
    StateHasChanged();
}


private void CalcolaTotaleOrdine()
{
    // Ricalcola il totale di ogni riga e poi il totale generale
    foreach (var r in ordine.Righe)
    {
        // Esempio: Quantità * Prezzo (meno eventuale sconto)
        r.PrezzoTotaleRiga = r.Quantita * r.PrezzoUnitario; 
    }
    
    // Somma tutti i totali riga nel totale ordine
    ordine.TotaleImponibile = ordine.Righe.Sum(x => x.PrezzoTotaleRiga);
    
    // Notifica a Blazor che i dati sono cambiati e deve ridisegnare la UI
    StateHasChanged();
}



    private async Task Prev() { if (indiceCorrente < listaIdOrdini.Count - 1) { indiceCorrente++; await CaricaOrdine(listaIdOrdini[indiceCorrente]); } }
    private async Task Next() { if (indiceCorrente > 0) { indiceCorrente--; await CaricaOrdine(listaIdOrdini[indiceCorrente]); } }


    


private void ApplicaSogliaConfezione(DettaglioOrdine riga)
{
    if (riga.PezziPerConfezione > 1)
    {
        // Se la quantità è 0 o negativa, ipotizziamo che voglia almeno 1 confezione
        decimal qDaCalcolare = riga.Quantita > 0 ? riga.Quantita : 1;

        decimal nConfezioni = Math.Ceiling(qDaCalcolare / (decimal)riga.PezziPerConfezione);
        riga.Quantita = nConfezioni * riga.PezziPerConfezione;
    }
}


private void OnQuantitaChanged(DettaglioOrdine riga, decimal nuovoValore)
{
    riga.Quantita = nuovoValore;

    if (riga.IsConfezione)
    {
        // Se il toggle è attivo, forziamo subito al multiplo superiore
        ApplicaSogliaConfezione(riga);
    }
    else
    {
        // Se il toggle è spento, aggiorniamo la "memoria" per il futuro
        riga.QuantitaOriginalePezzi = nuovoValore;
    }
    
    Ricalcola();
}

private void OnQuantitaModificata(DettaglioOrdine r)
{
    if (r.IsConfezione)
    {
        // Forza al multiplo se il toggle è attivo
        decimal nConfezioni = Math.Ceiling(r.Quantita / r.PezziPerConfezione);
        r.Quantita = nConfezioni * r.PezziPerConfezione;
    }
    else
    {
        // Salva in memoria per il futuro
        r.QuantitaOriginalePezzi = r.Quantita;
    }
    AggiornaConteggi(r);
}





