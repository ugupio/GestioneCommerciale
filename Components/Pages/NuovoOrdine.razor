        taskPendenti = (await db.QueryAsync<Attivita>(sql, new { id = ordine.IDCliente })).ToList();
    } catch { }
}

    private async Task CaricaOrdine(int id) {
    using var db = new SqlConnection(conn);
    
    // 1. Carica la testata
    ordine = await db.QueryFirstOrDefaultAsync<Ordine>("SELECT * FROM Ordini WHERE IDOrdine = @id", new { id });
    
    // 2. Carica le righe unendo la tabella Prodotti per recuperare i pezzi per confezione
    var sql = @"
    SELECT d.*, p.PezziPerConfezione, p.UMSecondaria 
    FROM Dettaglio_Ordini d
    LEFT JOIN Prodotti p ON d.CodiceProdotto = p.CodiceProdotto
    WHERE d.IDOrdine = @id";
    
var righe = await db.QueryAsync<DettaglioOrdine>(sql, new { id });
ordine.Righe = righe.ToList();

snapshotOrdineOriginale = JsonSerializer.Serialize(ordine); // Scatta la foto subito dopo il caricamento
// DEBUG MANUALE: Forza un valore se è 1 per testare il toggle
foreach(var r in ordine.Righe) {
    if(r.PezziPerConfezione <= 1) {
        // Se arriviamo qui, la query ha fallito il recupero dei pezzi
        // Prova a stampare in console per capire quale codice fallisce
        Console.WriteLine($"ERRORE: Pezzi non caricati per {r.CodiceProdotto}");
    }
}
SalvaStatoIniziale(); // Aggiorna lo snapshot dopo il caricamento
StateHasChanged();
}


    private bool IsPreventivo => string.Equals(ordine.StatoOrdine, "Preventivo", StringComparison.OrdinalIgnoreCase);

    private async Task Notifica(string msg) { testoNotifica = msg; mostraMessaggio = true; StateHasChanged(); await Task.Delay(3000); mostraMessaggio = false; StateHasChanged(); }
    
    
    private async Task IniziaNuovo()
{
    // Resettando l'ID a 0, la condizione (ordine.IDCliente == c.IdCliente) 
    // diventerà falsa per tutti i clienti, e la select tornerà sulla prima opzione.
    ordine = new Ordine 
    { 
        IDCliente = 0, 
        DataOrdine = DateTime.Now, 
        DataConsegnaPrevista = DateTime.Now.AddDays(7) 
    };

    indiceCorrente = -1; 
    Ricalcola();
    
    snapshotOrdineOriginale = JsonSerializer.Serialize(ordine);
    
    await Task.Yield();
    SalvaStatoIniziale(); // Aggiorna lo snapshot dopo aver inizializzato il nuovo ordine
    StateHasChanged();
}

    
    
    private async Task VaiA(Func<Task> azioneSpostamento)
{
    // Se lo snapshot è vuoto, significa che non abbiamo ancora una "foto" valida: lascia passare
    if (string.IsNullOrEmpty(snapshotOrdineOriginale))
    {
        await azioneSpostamento();
        return;
    }

    var snapshotAttuale = JsonSerializer.Serialize(ordine);

    if (snapshotAttuale != snapshotOrdineOriginale)
    {
        bool conferma = await JS.InvokeAsync<bool>("confirm", "⚠️ Ci sono modifiche non salvate. Vuoi uscire senza salvare?");
        if (!conferma) return;
    }

    await azioneSpostamento();
}


