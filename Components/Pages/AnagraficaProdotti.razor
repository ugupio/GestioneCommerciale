@page "/anagrafica-prodotti"
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Data.SqlClient
@using Dapper

<style>
    .win-form { background-color: #f0f0f0; font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 11px; border: 1px solid #999; padding: 5px; min-width: 1150px; color: #333; position: relative; min-height: 98vh; }
    .win-header { background: #005a9e; color: white; padding: 3px 8px; font-weight: bold; margin: -5px -5px 5px -5px; font-size: 12px; }
    .win-group { border: 1px solid #c0c0c0; background: #fff; padding: 8px; margin-bottom: 5px; }
    .win-label { font-weight: 500; color: #333; padding-right: 5px; white-space: nowrap; text-align: right; font-size: 10.5px; }
    .win-input { border: 1px solid #ccc; padding: 1px 4px; height: 21px; width: 100%; font-size: 11px; }
    .toolbar-container { display: flex; align-items: center; justify-content: flex-start; gap: 10px; padding: 5px; background: #fdfdfd; border: 1px solid #c0c0c0; margin-bottom: 5px; }
    .win-btn { background: #e1e1e1; border: 1px solid #adadad; padding: 0 15px; color: black; font-size: 11px; height: 72px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; min-width: 85px; text-decoration:none; flex-direction:column; }
    .win-btn:hover { background: #e5f1fb; border-color: #0078d7; }
    .section-title { font-weight: bold; color: #005a9e; border-bottom: 1px solid #ddd; margin-bottom: 8px; font-size: 10px; text-transform: uppercase; }
    
    /* Stile specifico per la tabella dati */
    .win-grid { width: 100%; border-collapse: collapse; background: white; }
    .win-grid th { background: #f0f0f0; border: 1px solid #ccc; padding: 4px; font-weight: bold; text-align: left; }
    .win-grid td { border: 1px solid #ccc; padding: 4px; }
    .win-btn-cell { background: #f0f0f0; border: 1px solid #ccc; cursor: pointer; padding: 0 5px; height: 20px; font-size: 10px; }
     /* Sfondo oscurato fisso */
    .win-modal-backdrop {
        position: fixed; /* Fondamentale: resta fisso rispetto alla finestra */
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 10000;
        display: flex;
        align-items: center; /* Centra verticalmente */
        justify-content: center; /* Centra orizzontalmente */
    }

    /* Finestra centrata */
    .win-popup {
        width: 500px;
        background: #f0f0f0;
        border: 1px solid #666;
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        animation: fadeIn 0.2s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .btn-xs {
    padding: 0.1rem 0.4rem;
    font-size: 0.75rem;
}

/* Evita che il testo della descrizione rompa il layout se troppo lungo */
.text-truncate {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.win-btn-tablet {
    padding: 8px 12px; /* Più spazio interno */
    font-size: 1.2rem;   /* Icona più grande */
    min-width: 45px;    /* Larghezza minima garantita */
    min-height: 45px;   /* Altezza minima per il pollice */
    margin: 2px;        /* Distanza tra i tasti */
    border-radius: 6px;
    border: 1px solid #ccc;
    background: #f8f9fa;
    transition: background 0.2s;
}

.win-btn-tablet:active {
    background: #e2e6ea; /* Feedback visivo al tocco */
    transform: scale(0.95);
}

</style>





<div class="win-form">
    <div class="win-header d-flex justify-content-between">
        <span>📦 GESTIONE PRODOTTI (PROFILI E ACCESSORI) by Riccardo Gucci soft.</span>
        <button class="btn-close btn-close-white" @onclick='() => Nav.NavigateTo("/")'></button>
    </div>

    <div class="toolbar-container">
        <!-- 1. HOME -->
    <button class="win-btn" @onclick='() => Nav.NavigateTo("/")'>
        <span style="font-size: 20px;">🏠</span><br />
        Home
    </button>

    <!-- 2. AGGIORNA -->
    <button class="win-btn" @onclick="RicaricaLista">
        <span style="font-size: 20px;">🔄</span><br />
        Aggiorna
    </button>

    <!-- 3. NUOVO -->
    <button class="win-btn" @onclick="ApriNuovoDaAnagrafica">
        <span style="font-size: 20px;">➕</span><br />
        Nuovo
    </button>
    </div>
    <div class="win-group" style="background: #f0f0f0;">
    <div class="win-group" style="background: #f0f0f0; padding: 5px;">
    <div style="display: flex; align-items: center; justify-content: flex-start; gap: 15px;">
        
        <!-- PARTE RICERCA (Larghezza fissa per non spingere troppo) -->
        <div style="display: flex; align-items: center; white-space: nowrap;">
            <label class="win-label" style="margin: 0 5px 0 0;">Cerca:</label>
            <input class="win-input" style="width: 220px;" @oninput="FiltraProdotti" placeholder="Codice o descrizione..." />
        </div>

        <!-- CONTATORI (Tutti in fila con i Badge belli) -->
        <div style="display: flex; align-items: center; gap: 10px; white-space: nowrap;">
            
            <span style="background:#6c757d; color:white; padding:3px 10px; font-size:10.5px; border-radius:3px; border:1px solid #545b62;">
                🔎 Trovati: <b>@listaFiltrata.Count</b>
            </span>

            <span style="background:#005a9e; color:white; padding:3px 10px; font-size:10.5px; border-radius:3px; border:1px solid #004a87;">
                📦 Profili: <b>@listaFiltrata.Count(p => !p.IsAccessorio)</b>
            </span>

            <span style="background:#28a745; color:white; padding:3px 10px; font-size:10.5px; border-radius:3px; border:1px solid #1e7e34;">
                🛠️ Accessori: <b>@listaFiltrata.Count(p => p.IsAccessorio)</b>
            </span>
            
        </div>
    </div>
</div>
</div>
    <div class="win-group">
        <div class="section-title">Elenco Articoli a Listino</div>
        <div style="max-height: 70vh; overflow-y: auto;">
            <table class="win-grid" style="width:100%">
                <thead>
                    <tr style="background:#f0f0f0; position: sticky; top: 0;">
                        <th style="width:100px">Codice</th>
                        <th style="width:80px">Tipo</th>
                        <th>Descrizione</th> 
                        <th style="width:350px">Note Tecniche</th> 
                        <th style="width:90px" class="text-end">Kg/ml</th>
                        <th style="width:50px">U.M.</th>
                        <th style="width:200px" class="text-center">Azione</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in listaFiltrata)
                    {
                    <tr>
                    <td class="fw-bold">@p.CodiceProdotto</td>
                    <td>@(p.IsAccessorio ? "🛠️ ACC" : "📦 PROF")</td>
                    <td>@p.Descrizione</td>
        
                    <!-- CELLA NOTE CON ICONA -->
                        <td style="color: #005a9e; font-style: italic; font-size: 10px;">
                            @(string.IsNullOrWhiteSpace(p.NoteTecniche) ? "-" : p.NoteTecniche)
                        </td>

                        <td class="text-end">@(p.IsAccessorio ? "-" : p.PesoAlMetro.ToString("N3"))</td>
                        <td>@p.UmProdotto</td>
                        <td class="text-center">
                <!-- NUOVO TASTO RADAR -->
                <button class="win-btn-tablet text-primary" @onclick="() => ApriModalRadar(p)" title="Radar">
        🔍
    </button>
    
    <!-- EDIT (Matita) -->
    <button class="win-btn-tablet text-dark" @onclick="() => ApriModifica(p)" title="Modifica">
        ✏️
    </button>
    
    <!-- DELETE (Cestino) -->
    <button class="win-btn-tablet text-danger" @onclick="() => EliminaProdotto(p.IDProdotto)" title="Elimina">
        🗑️
    </button>
            </td>
    </tr>
}
                </tbody>
            </table>
        </div>
    </div>
    @if (mostraPopupModifica)
{
    <div class="win-modal-backdrop">
        <div class="win-popup" style="width: 500px;">
            <div class="win-header d-flex justify-content-between">
                <span>✏️ MODIFICA SCHEDA PRODOTTO</span>
                <span style="cursor:pointer" @onclick="() => mostraPopupModifica = false">×</span>
            </div>
            
            <div class="popup-body">
                <div class="win-group" style="background: #f9f9f9;">
                    <div class="row mb-2">
                        <div class="col-4">
                            <label class="win-label d-block text-start">Codice:</label>
                                @if (prodottoInModifica.IDProdotto == 0)
    {
        <!-- SE NUOVO: Diventa rosso se il codice esiste già -->
        <input class="win-input fw-bold" 
               value="@prodottoInModifica.CodiceProdotto" 
               @oninput="VerificaDuplicato"
               style="background: @(codiceDuplicato ? "#ffcccc" : "#fffde7");" 
               placeholder="Inserisci cod..." />
        
        @if (codiceDuplicato)
        {
            <small class="text-danger" style="font-size: 8px; font-weight:bold;">⚠️ Codice già presente!</small>
        }
    }
    else
    {
        <!-- SE ESISTENTE: Grigio come prima -->
        <input class="win-input fw-bold" @bind="prodottoInModifica.CodiceProdotto" style="background: #eee;" />
        <small class="text-muted" style="font-size: 8px;">Si consiglia di non modificare il Codice se esistono Ordini Caricati</small>                   
    }
                            </div>
                        <div class="col-8">
                            <label class="win-label d-block text-start">Descrizione:</label>
                            <input class="win-input" @bind="prodottoInModifica.Descrizione" />
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-6">
    <label class="win-label d-block text-start">Tipo Articolo:</label>
    @if (prodottoInModifica.IDProdotto == 0) {
        <!-- Se è NUOVO, posso scegliere -->
        <select class="win-input" 
        value="@prodottoInModifica.IsAccessorio.ToString().ToLower()" 
        @onchange="@((ChangeEventArgs e) => { 
            prodottoInModifica.IsAccessorio = bool.Parse(e.Value.ToString()); 
            StateHasChanged(); 
        })">
    <option value="false">📦 PROFILO</option>
    <option value="true">🛠️ ACCESSORIO</option>
</select>
    } else {
        <!-- Se è MODIFICA, è bloccato -->
        <div class="win-input" style="background:#e9ecef; font-weight:bold; display:flex; align-items:center;">
            @(prodottoInModifica.IsAccessorio ? "🛠️ ACCESSORIO" : "📦 PROFILO")
        </div>
    }
</div>

                        <div class="col-6">
                            <label class="win-label d-block text-start">Unità di Misura:</label>
                            <input class="win-input" @bind="prodottoInModifica.UmProdotto" placeholder="ML o PZ" />
                        </div>
                    </div>

                    @if (!prodottoInModifica.IsAccessorio)
                    {
                        <div class="row mt-3 p-2" style="background: #eef6ff; border: 1px solid #b4c7e7;">
                            <div class="col-6">
                                <label class="win-label d-block text-start">Peso (Kg/ml):</label>
                                <input type="number" step="0.001" class="win-input" @bind="prodottoInModifica.PesoAlMetro" />
                            </div>
                            <div class="col-6">
                                <label class="win-label d-block text-start">Lunghezza (m):</label>
                                <input type="number" step="0.01" class="win-input" @bind="prodottoInModifica.LunghezzaVerga" />
                            </div>
                        </div>
                    }
                </div>
                <div class="mb-2 mt-2">
                    <label class="win-label d-block text-start">Note Tecniche / Appunti:</label>
                    <textarea class="win-input" @bind="prodottoInModifica.NoteTecniche" 
                    style="height: 50px; resize: none;" 
                    placeholder="Inserisci dettagli tecnici, compatibilità..."></textarea>
                </div>

                <div class="mt-4 d-flex align-items-center justify-content-end gap-2">
                    <button class="win-btn" style="height:40px; background:#005a9e; color:white; min-width: 120px;" @onclick="SalvaModifiche">
                        <span class="oi oi-check"></span> REGISTRA
                    </button>
                    <button class="win-btn" style="height:40px; min-width: 100px;" @onclick="() => mostraPopupModifica = false">
                        ANNULLA
                    </button>
                </div>
            </div>
        </div>
    </div>
}



@if (!string.IsNullOrEmpty(messaggioInfo))
{
    <!-- Sfondo scuro leggero per far risaltare il messaggio -->
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.1); z-index: 9998;"></div>

    <!-- Messaggio al centro esatto -->
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999; 
                background: white; border: 2px solid #ffc107; color: #856404; 
                padding: 30px 50px; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.2);
                text-align: center; min-width: 400px; animation: popIn 0.3s ease-out;">
        
        <div style="font-size: 40px; margin-bottom: 10px;">⚠️</div>
        <div style="font-size: 18px; font-weight: bold; margin-bottom: 5px;">ATTENZIONE</div>
        <div style="font-size: 16px;">@messaggioInfo</div>
    </div>
}

<style>
    @@keyframes popIn { 
        0% { opacity: 0; transform: translate(-50%, -60%) scale(0.9); } 
        100% { opacity: 1; transform: translate(-50%, -50%) scale(1); } 
    }
</style>




@if (mostraModalRadar)
{
    <!-- Sfondo oscurante con effetto sfocatura (Blur) -->
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; 
                background: rgba(0, 0, 0, 0.3); backdrop-filter: blur(4px); z-index: 1040;"></div>

    <!-- Popup in stile Windows Glass -->
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); 
                z-index: 1050; width: 90%; max-width: 1200px; 
                background: rgba(255, 255, 255, 0.85);
                box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
                border-radius: 8px; border: 2px solid #005a9e; overflow: hidden;">
        
        <!-- Header -->
        <div style="background: #005a9e; color: white; padding: 12px 18px; display: flex; justify-content: space-between; align-items: center;">
            <h5 style="margin: 0; font-size: 18px; font-weight: bold;">🔍 Analisi Commerciale: @prodottoSelezionatoRadar?.CodiceProdotto</h5>
            <button class="win-btn-tablet" style="background: #c42b1c; color: white; border: none; min-width: 40px; min-height: 40px;" 
                    @onclick="() => mostraModalRadar = false">✕</button>
        </div>
        
        <div style="padding: 20px; max-height: 80vh; overflow-y: auto;">
            
            <!-- SEZIONE BI: BOX KPI PER TABLET -->
            @if (statsPrezzi != null)
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-bottom: 20px;">
                    <div style="background: rgba(0, 90, 158, 0.1); border-left: 6px solid #005a9e; padding: 12px; border-radius: 4px;">
                        <div style="font-size: 11px; color: #555; text-transform: uppercase;">Prezzo Medio</div>
                        <div style="font-size: 20px; font-weight: bold; color: #005a9e;">€ @((statsPrezzi?.Media as double?)?.ToString("N2") ?? "0,00")</div>
                    </div>
                    <div style="background: rgba(40, 167, 69, 0.1); border-left: 6px solid #28a745; padding: 12px; border-radius: 4px;">
                        <div style="font-size: 11px; color: #555; text-transform: uppercase;">Prezzo Max</div>
                        <div style="font-size: 20px; font-weight: bold; color: #28a745;">€ @statsPrezzi.Massimo?.ToString("N2")</div>
                    </div>
                    <div style="background: rgba(220, 53, 69, 0.1); border-left: 6px solid #dc3545; padding: 12px; border-radius: 4px;">
                        <div style="font-size: 11px; color: #555; text-transform: uppercase;">Prezzo Min</div>
                        <div style="font-size: 20px; font-weight: bold; color: #dc3545;">€ @statsPrezzi.Minimo?.ToString("N2")</div>
                    </div>
                    <div style="background: rgba(108, 117, 125, 0.1); border-left: 6px solid #6c757d; padding: 12px; border-radius: 4px;">
                        <div style="font-size: 11px; color: #555; text-transform: uppercase;">Volume Totale</div>
                        <div style="font-size: 20px; font-weight: bold; color: #333;">@((statsPrezzi?.VolumeTotale as decimal?)?.ToString("N0") ?? "0") <small style="font-size: 12px;">@prodottoSelezionatoRadar?.UmProdotto</small></div>
                    </div>
                </div>
            }

            <!-- Barra di ricerca -->
            <div style="margin-bottom: 15px;">
                <input type="text" class="form-control form-control-lg" 
                       style="background: rgba(255, 255, 255, 0.6); border: 2px solid #005a9e; height: 50px;"
                       placeholder="Filtra per colore o finitura..." 
                       @bind="filtroColoreRadar" @bind:event="oninput" @onkeyup="EseguiRicercaRadar" />
            </div>

            <!-- Tabella Risultati -->
            <table class="table table-hover align-middle" style="background: transparent;">
                <thead style="background: rgba(0, 0, 0, 0.05);">
                    <tr>
                        <th>Data</th>
                        <th>Cliente</th>
                        <th>Colori / Finitura</th>
                        <th class="text-end">Prezzo Unit.</th> <!-- BI: Aggiunto prezzo specifico -->
                        <th class="text-end">Quantità</th>
                        <th class="text-center">U.M.</th>
                        <th class="text-center">Contatti</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in listaRisultatiRadar)
    {
        <tr style="background: rgba(255, 255, 255, 0.4); border-bottom: 1px solid #ddd;">
            <!-- Data -->
            <td>@(((DateTime)r.DataOrdine).ToShortDateString())</td>
            
            <!-- Ragione Sociale -->
            <td style="font-weight: bold; text-transform: uppercase;">@r.RagSociale?.ToString()</td>
            
            <!-- Colori e Finitura -->
            <td>
                <span style="color: #005a9e; font-weight: 500;">@r.ColoreInt?.ToString()</span> 
                <span style="color: #666;">@r.ColoreEst?.ToString()</span> 
                <i style="display: block; font-size: 0.8em; color: #777;">@r.FinituraAccessorio?.ToString()</i>
            </td>
            
            <!-- Prezzo Unitario -->
            <td class="text-end fw-bold" style="color: #28a745;">
    € @(r.PrezzoUnitario != null ? Convert.ToDecimal(r.PrezzoUnitario).ToString("N2") : "0,00")
</td>
            
            <!-- Quantità -->
            <td class="text-end fw-bold">
                @(Convert.ToDecimal(r.Quantita).ToString("N2"))
            </td>
            
            <!-- Unità di Misura -->
            <td class="text-center small">@r.UmRiga?.ToString()</td>
            
            <!-- Contatti -->
            <td class="text-center">
                @if (!string.IsNullOrEmpty(r.Cel1?.ToString()))
                {
                    <a href="tel:@r.Cel1?.ToString()" class="win-btn-tablet" 
   style="text-decoration: none; display: inline-flex; align-items: center; justify-content: center; width: 45px; height: 45px; padding: 0;">
    📞
</a>

                }
            </td>
        </tr>
    }
                </tbody>
            </table>
        </div>

        <!-- Footer per Tablet -->
        <div style="background: rgba(0, 0, 0, 0.05); padding: 15px; text-align: center;">
            <button class="win-btn-tablet" style="width: 100%; max-width: 300px; font-weight: bold;" 
                    @onclick="() => mostraModalRadar = false">CHIUDI ANALISI</button>
        </div>
    </div>
}





</div>

@code {
    private string conn = @"Server=.\SQLEXPRESS;Database=GestAgenti;Trusted_Connection=True;TrustServerCertificate=True;";
    private List<Prodotti> listaProdotti = new();
    private string testoRicerca = ""; // Ricerca principale tabella prodotti

    // Gestione Modifica
    private bool mostraPopupModifica = false;
    private Prodotti prodottoInModifica = new();
    private bool codiceDuplicato = false;

    // Gestione Radar Stock (Rinominate per evitare duplicati)
    private bool mostraModalRadar = false; 
    private string filtroColoreRadar = ""; 
    private Prodotti prodottoSelezionatoRadar;
    private IEnumerable<dynamic> listaRisultatiRadar = new List<dynamic>();
    private string messaggioInfo = "";
    private dynamic statsPrezzi;
    private string biMedia = "---";
private string biMinimo = "---";
private string biMassimo = "---";
private string biVolume = "0";


    protected override async Task OnInitializedAsync()
    {
        await RicaricaLista();
    }

    private async Task<bool> VerificaCodiceEsistente(string codice)
{
    if (string.IsNullOrWhiteSpace(codice)) return false;

    using var db = new SqlConnection(conn);
    // Controlliamo se esiste un prodotto con lo stesso codice (escludendo l'attuale se siamo in modifica)
    var esiste = await db.ExecuteScalarAsync<int>(
        "SELECT COUNT(1) FROM Prodotti WHERE CodiceProdotto = @codice", 
        new { codice });

    return esiste > 0;
}
    
    
private async Task VerificaDuplicato(ChangeEventArgs e)
{
    string cod = e.Value?.ToString() ?? "";
    prodottoInModifica.CodiceProdotto = cod; // Aggiorna l'oggetto manualmente

    if (string.IsNullOrWhiteSpace(cod))
    {
        codiceDuplicato = false;
        return;
    }

    using var db = new SqlConnection(conn);
    // Conta quanti prodotti hanno questo codice
    var conteggio = await db.ExecuteScalarAsync<int>(
        "SELECT COUNT(1) FROM Prodotti WHERE CodiceProdotto = @cod", 
        new { cod });

    codiceDuplicato = conteggio > 0;
}


private async Task RicaricaLista()
    {
        using var db = new SqlConnection(conn);
        listaProdotti = (await db.QueryAsync<Prodotti>("SELECT * FROM Prodotti ORDER BY CodiceProdotto")).ToList();
    }

    private void ApriNuovoDaAnagrafica()
    {
        // Prepariamo l'oggetto vuoto per un nuovo inserimento
        prodottoInModifica = new Prodotti { UmProdotto = "ML", IsAccessorio = false, CodiceProdotto = "", Descrizione = "" };

    // Cambiamo il titolo o usiamo un flag per capire se è un INSERT o un UPDATE
    // Per semplicità, possiamo usare lo stesso popup di modifica adattando il tasto Salva
    mostraPopupModifica = true; 
}
    
    private async Task EliminaProdotto(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Sei sicuro di voler eliminare questo prodotto dal listino?")) return;
        
        using var db = new SqlConnection(conn);
        await db.ExecuteAsync("DELETE FROM Prodotti WHERE IDProdotto = @id", new { id });
        await RicaricaLista();
    }

    private void ApriModifica(Prodotti p)
{
    prodottoInModifica = new Prodotti 
    { 
        IDProdotto = p.IDProdotto,
        CodiceProdotto = p.CodiceProdotto,
        Descrizione = p.Descrizione,
        IsAccessorio = p.IsAccessorio,
        PesoAlMetro = p.PesoAlMetro,
        LunghezzaVerga = p.LunghezzaVerga,
        UmProdotto = p.UmProdotto,
        NoteTecniche = p.NoteTecniche
    };
    mostraPopupModifica = true;
}

private async Task SalvaModifiche()
{
    using var db = new SqlConnection(conn);
    string sql;

    // Blocca il salvataggio se è un nuovo inserimento e il codice è doppio
    if (prodottoInModifica.IDProdotto == 0 && codiceDuplicato)
    {
        await JS.InvokeVoidAsync("alert", "Impossibile salvare: il codice inserito è già utilizzato per un altro prodotto.");
        return;
    }
    
    
    if (prodottoInModifica.IDProdotto == 0) // È UN NUOVO RECORD
    {
        sql = @"INSERT INTO Prodotti (CodiceProdotto, Descrizione, IsAccessorio, PesoAlMetro, LunghezzaVerga, UmProdotto, NoteTecniche, FinituraAccessorio) 
                VALUES (@CodiceProdotto, @Descrizione, @IsAccessorio, @PesoAlMetro, @LunghezzaVerga, @UmProdotto, @NoteTecniche, '')";
    }
    else // È UNA MODIFICA
    {
        sql = @"UPDATE Prodotti SET CodiceProdotto = @CodiceProdotto, Descrizione = @Descrizione, 
                PesoAlMetro = @PesoAlMetro, LunghezzaVerga = @LunghezzaVerga, UmProdotto = @UmProdotto , NoteTecniche = @NoteTecniche
                WHERE IDProdotto = @IDProdotto";
    }
    
    await db.ExecuteAsync(sql, prodottoInModifica);
    mostraPopupModifica = false;
    await RicaricaLista();
}



    
