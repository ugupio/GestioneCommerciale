}




private async Task EseguiRicercaRadar()
{
    if (prodottoSelezionatoRadar == null) return;
    using var db = new Microsoft.Data.SqlClient.SqlConnection(conn);
    
    string sql = @"
        SELECT O.DataOrdine, C.RagSociale, D.Quantita, D.ColoreInt, D.ColoreEst, D.FinituraAccessorio, C.Cel1, D.UmRiga, D.PrezzoUnitario
        FROM Dettaglio_Ordini D
        JOIN Ordini O ON D.IDOrdine = O.IDOrdine
        JOIN Clienti C ON O.IDCliente = C.IdCliente
        WHERE LTRIM(RTRIM(D.CodiceProdotto)) = LTRIM(RTRIM(@Codice))
        ORDER BY O.DataOrdine DESC";

    var result = await db.QueryAsync(sql, new { Codice = prodottoSelezionatoRadar.CodiceProdotto });
    listaRisultatiRadar = result.ToList();
}


